css:
    .methodology-page {
        color: #241f1a;
        display: flex;
        flex: 1;
        flex-direction: column;
        min-height: 100%;
        padding-bottom: 3.5rem;
    }

    .methodology-page .methodology-container {
        flex: 1;
        max-width: 920px;
    }

    .methodology-page .methodology-back-link {
        color: #8c1515;
        display: inline-block;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 1.75rem;
        text-decoration: none;
    }

    .methodology-page .methodology-back-link:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .methodology-page .methodology-hero {
        margin-bottom: 2.5rem;
    }

    .methodology-page .methodology-title {
        color: #2b2926;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.05;
        margin-bottom: 0.65rem;
    }

    .methodology-page .methodology-lead {
        color: #3f3933;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.08rem;
        line-height: 1.65;
        margin: 0;
        max-width: 42rem;
    }

    .methodology-page .methodology-section {
        margin-bottom: 2.5rem;
    }

    .methodology-page .methodology-section-label {
        color: #8b8379;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        margin-bottom: 0.85rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-field-grid {
        display: grid;
        gap: 0.85rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .methodology-page .methodology-field-card {
        background: #f0ebe3;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        padding: 1rem 1.1rem;
    }

    .methodology-page .methodology-field-label {
        color: #2b2926;
        font-size: 0.92rem;
        font-weight: 700;
        line-height: 1.3;
        margin-bottom: 0.35rem;
    }

    .methodology-page .methodology-field-desc {
        color: #3f3933;
        font-size: 0.88rem;
        line-height: 1.55;
        margin: 0;
    }

    .methodology-page .methodology-rule-list {
        border-top: 1px solid #e1dccf;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .methodology-page .methodology-rule-item {
        border-bottom: 1px solid #e1dccf;
        color: #3f3933;
        font-size: 0.92rem;
        line-height: 1.6;
        padding: 0.95rem 0;
    }

    .methodology-page .methodology-rule-item strong {
        color: #2b2926;
        font-weight: 700;
    }

    .methodology-page .methodology-convention-list {
        color: #3f3933;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.02rem;
        line-height: 1.75;
        margin: 0;
        padding-left: 1.25rem;
    }

    .methodology-page .methodology-convention-list li {
        margin-bottom: 0.65rem;
    }

    .methodology-page .methodology-convention-list li:last-child {
        margin-bottom: 0;
    }

    .methodology-page .methodology-citation-box {
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(36, 31, 26, 0.08);
        border-radius: 0.85rem;
        color: #3f3933;
        font-size: 0.92rem;
        line-height: 1.65;
        padding: 1rem 1.15rem;
    }

    .methodology-page .methodology-citation-box p {
        margin: 0 0 0.75rem;
    }

    .methodology-page .methodology-citation-box p:last-child {
        margin-bottom: 0;
    }

    .methodology-page .methodology-link {
        color: #8c1515;
        font-weight: 600;
        text-decoration: none;
    }

    .methodology-page .methodology-link:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .methodology-page .methodology-meta-note {
        border-top: 1px solid rgba(36, 31, 26, 0.08);
        color: #8b8379;
        font-size: 0.78rem;
        margin-top: 1rem;
        padding-top: 1.5rem;
    }

    @media (max-width: 767.98px) {
        .methodology-page .methodology-field-grid {
            grid-template-columns: 1fr;
        }
    }

- content_for :title, "Data Methodology"
- content_for :description, "Fields, sources, and visibility rules for CodeX TechIndex company profiles and statistics dashboards."
- profile_fields = [{ label: "Name, description, website", desc: "Core identity fields sourced from public company information and CodeX research." }, { label: "Founded date", desc: "Four-digit founding year when available; used for growth and cohort statistics (typically 2000+)." }, { label: "Location", desc: "Headquarters city/region/country; normalized for geographic charts." }, { label: "Category", desc: "Primary legal tech segment (e.g. contracts, litigation, research)." }, { label: "Business model & target client", desc: "Go-to-market and monetization classification." }, { label: "Tags", desc: "Technology themes (e.g. AI, analytics) applied across the ecosystem." }, { label: "Funding", desc: "Total disclosed venture capital in USD when reported; absent values are treated as undisclosed." }, { label: "Status", desc: "Operating status (active, acquired, etc.) when known." }]
- visibility_rules = [{ term: "Visible profiles", detail: "Only companies marked visible appear in the public directory and statistics. Hidden profiles are excluded from all public counts and charts." }, { term: "Unknown category", detail: "Excluded from category-based statistics." }, { term: "Minimum segment size", detail: "Some breakdowns (business model, target client) hide segments with fewer than 10 companies." }]
- stat_conventions = ["Charts show counts as of #{Date.current.strftime("%B %-d, %Y")} based on #{number_with_delimiter(visible_company_count)} visible companies unless noted otherwise.", "Ecosystem growth charts use cumulative totals or annual new companies depending on the selected view.", "Category evolution charts show cumulative companies founded through each period end, not new companies per period alone.", "Funding charts include only companies with disclosed funding amounts greater than zero.", "Geographic charts require a valid headquarters location and typically filter to companies founded in 2000 or later."]

.methodology-page
    .container.methodology-container.py-4.py-lg-5
        = link_to statistics_path, class: "methodology-back-link" do
            | ← All statistics

        header.methodology-hero
            h1.methodology-title Data Methodology
            p.methodology-lead How CodeX TechIndex collects, curates, and presents legal tech company data for research and public reference.

        section.methodology-section
            .methodology-section-label Company profile fields
            .methodology-field-grid
                - profile_fields.each do |field|
                    .methodology-field-card
                        .methodology-field-label= field[:label]
                        p.methodology-field-desc= field[:desc]

        section.methodology-section
            .methodology-section-label Visibility rules
            ul.methodology-rule-list
                - visibility_rules.each do |rule|
                    li.methodology-rule-item
                        strong= "#{rule[:term]}:"
                        = " #{rule[:detail]}"

        section.methodology-section
            .methodology-section-label Statistics conventions
            ul.methodology-convention-list
                - stat_conventions.each do |convention|
                    li= convention

        section.methodology-section
            .methodology-section-label Sources & citation
            .methodology-citation-box
                p
                    | Data is curated by
                    = link_to " CodeX, the Stanford Center for Legal Informatics", "https://law.stanford.edu/codex-the-stanford-center-for-legal-informatics/", target: "_blank", rel: "noopener", class: "methodology-link"
                    | , with contributions from Legal.io and community submissions. When citing TechIndex data, include the page URL, access date, and note visibility/funding caveats above.
                p
                    | AI-friendly overview:
                    = link_to " llms.txt", "/llms.txt", class: "methodology-link"

        .methodology-meta-note
            | Document maintained by Stanford CodeX. Last updated #{Date.current.strftime("%B %Y")}.
