css:
    .methodology-page {
        color: #241f1a;
        display: flex;
        flex: 1;
        flex-direction: column;
        min-height: 100%;
        padding-bottom: 3.5rem;
    }

    .methodology-page .methodology-container {
        flex: 1;
        max-width: 980px;
    }

    .methodology-page .methodology-back-link {
        color: #8c1515;
        display: inline-block;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 1.75rem;
        text-decoration: none;
    }

    .methodology-page .methodology-back-link:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .methodology-page .methodology-hero {
        margin-bottom: 2.5rem;
    }

    .methodology-page .methodology-title {
        color: #2b2926;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.05;
        margin-bottom: 0.65rem;
    }

    .methodology-page .methodology-lead {
        color: #3f3933;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.08rem;
        line-height: 1.65;
        margin: 0;
        max-width: 44rem;
    }

    .methodology-page .methodology-section {
        margin-bottom: 2.75rem;
    }

    .methodology-page .methodology-section-label {
        color: #8b8379;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        margin-bottom: 0.85rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-section-intro {
        color: #3f3933;
        font-size: 0.94rem;
        line-height: 1.65;
        margin: 0 0 1rem;
        max-width: 44rem;
    }

    .methodology-page .methodology-table-wrap {
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        overflow-x: auto;
    }

    .methodology-page .methodology-table {
        border-collapse: collapse;
        font-size: 0.88rem;
        line-height: 1.5;
        margin: 0;
        min-width: 640px;
        width: 100%;
    }

    .methodology-page .methodology-table th {
        background: #f0ebe3;
        border-bottom: 1px solid #e1dccf;
        color: #2b2926;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        padding: 0.75rem 1rem;
        text-align: left;
        text-transform: uppercase;
        vertical-align: top;
    }

    .methodology-page .methodology-table td {
        border-bottom: 1px solid #ece7de;
        color: #3f3933;
        padding: 0.85rem 1rem;
        vertical-align: top;
    }

    .methodology-page .methodology-table tbody tr:last-child td {
        border-bottom: none;
    }

    .methodology-page .methodology-table .field-name {
        color: #2b2926;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.82rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .methodology-page .methodology-table .field-type {
        color: #6b645b;
        font-size: 0.82rem;
        white-space: nowrap;
    }

    .methodology-page .methodology-table .category-name {
        color: #2b2926;
        font-weight: 700;
        min-width: 11rem;
    }

    .methodology-page .methodology-table .category-count {
        color: #6b645b;
        font-size: 0.82rem;
        text-align: right;
        white-space: nowrap;
    }

    .methodology-page .methodology-table .category-count-note {
        color: #8b8379;
        font-size: 0.72rem;
        font-weight: 600;
        margin-left: 0.25rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-table .category-status {
        color: #6b645b;
        font-size: 0.82rem;
        white-space: nowrap;
    }

    .methodology-page .methodology-planned-label {
        color: #8c1515;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-left: 0.5rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-table th.text-end,
    .methodology-page .methodology-table td.text-end {
        text-align: right;
    }

    .methodology-page .methodology-group-label {
        background: rgba(240, 235, 227, 0.55);
        color: #6b645b;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        padding: 0.55rem 1rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-principle-box {
        background: #f0ebe3;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        color: #3f3933;
        font-size: 0.92rem;
        line-height: 1.65;
        margin-bottom: 1.25rem;
        padding: 1rem 1.15rem;
    }

    .methodology-page .methodology-principle-box p {
        margin: 0;
    }

    .methodology-page .methodology-convention-list {
        color: #3f3933;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.02rem;
        line-height: 1.75;
        margin: 0;
        padding-left: 1.25rem;
    }

    .methodology-page .methodology-convention-list li {
        margin-bottom: 0.65rem;
    }

    .methodology-page .methodology-convention-list li:last-child {
        margin-bottom: 0;
    }

    .methodology-page .methodology-citation-box {
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(36, 31, 26, 0.08);
        border-radius: 0.85rem;
        color: #3f3933;
        font-size: 0.92rem;
        line-height: 1.65;
        padding: 1rem 1.15rem;
    }

    .methodology-page .methodology-citation-box p {
        margin: 0 0 0.75rem;
    }

    .methodology-page .methodology-citation-box p:last-child {
        margin-bottom: 0;
    }

    .methodology-page .methodology-link {
        color: #8c1515;
        font-weight: 600;
        text-decoration: none;
    }

    .methodology-page .methodology-link:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .methodology-page .methodology-meta-note {
        border-top: 1px solid rgba(36, 31, 26, 0.08);
        color: #8b8379;
        font-size: 0.78rem;
        margin-top: 1rem;
        padding-top: 1.5rem;
    }

- content_for :title, "Data Methodology & Dictionary"
- content_for :description, "Data dictionary, classification scheme, and statistics conventions for the Stanford CodeX TechIndex legal technology index."
- category_rows = methodology_category_rows
- company_count = visible_company_count

.methodology-page
    .container.methodology-container.py-4.py-lg-5
        = link_to statistics_path, class: "methodology-back-link" do
            | ← All statistics

        header.methodology-hero
            h1.methodology-title Data Methodology & Dictionary
            p.methodology-lead How the TechIndex defines company profiles, classification, and statistics.

        section.methodology-section
            .methodology-section-label Overview
            .methodology-principle-box
                p= "#{methodology_overview_guidance(number_with_delimiter(company_count))}"
            .methodology-table-wrap.mt-3
                table.methodology-table
                    thead
                        tr
                            th Situation
                            th Policy
                    tbody
                        - methodology_entity_relationships.each do |row|
                            tr
                                td.category-name= row[:term]
                                td= row[:definition]

        section.methodology-section
            .methodology-section-label Company data dictionary
            p.methodology-section-intro Profile fields stored on each company record.

            .methodology-table-wrap
                table.methodology-table
                    thead
                        tr
                            th Field
                            th Type
                            th Description
                    tbody
                        - methodology_company_field_groups.each do |group|
                            tr
                                td.methodology-group-label colspan="3"= group[:label]
                            - group[:fields].each do |field|
                                tr
                                    td
                                        span.field-name= field[:name]
                                    td.field-type= field[:type]
                                    td= field[:description]

        section.methodology-section
            .methodology-section-label Categorization
            p.methodology-section-intro= methodology_category_guidance

            .methodology-section-label.mt-4 Primary categories (12)
            .methodology-table-wrap
                table.methodology-table
                    thead
                        tr
                            th Category
                            th Definition
                            th.text-end Count
                    tbody
                        - category_rows.each do |row|
                            tr
                                td.category-name= row[:name]
                                td= row[:definition]
                                td.category-count.text-end= number_with_delimiter(row[:count])

            .methodology-section-label.mt-4 Secondary category
            p.methodology-section-intro= methodology_secondary_category_guidance

            .methodology-section-label.mt-4 Revenue models
            p.methodology-section-intro= methodology_revenue_model_guidance

            .methodology-table-wrap
                table.methodology-table
                    thead
                        tr
                            th Model
                            th Definition
                    tbody
                        - methodology_revenue_models.each do |row|
                            tr
                                td.category-name= row[:name]
                                td= row[:definition]

            .methodology-section-label.mt-4 Target clients
            p.methodology-section-intro Canonical audience values; a company may have one or more.

            .methodology-table-wrap
                table.methodology-table
                    thead
                        tr
                            th Value
                            th Definition
                    tbody
                        - methodology_target_clients.each do |row|
                            tr
                                td.category-name= row[:name]
                                td= row[:definition]

            p.methodology-section-intro.mt-4 Tags cross-cut categories for technology-theme and AI charts (e.g. artificial intelligence, ediscovery, saas).

        section.methodology-section
            .methodology-section-label Statistics conventions
            ul.methodology-convention-list
                - methodology_statistics_conventions.each do |convention|
                    li= convention

        section.methodology-section
            .methodology-section-label Sources & citation
            .methodology-citation-box
                p
                    | Data is curated by
                    = link_to " CodeX, the Stanford Center for Legal Informatics", "https://law.stanford.edu/codex-the-stanford-center-for-legal-informatics/", target: "_blank", rel: "noopener", class: "methodology-link"
                    | , with contributions from Legal.io and community submissions. Cite the page URL, access date, and note classification caveats above.
                p
                    | AI-friendly overview:
                    = link_to " llms.txt", "/llms.txt", class: "methodology-link"

        .methodology-meta-note
            | Field definitions may evolve; major taxonomy changes are documented here.
