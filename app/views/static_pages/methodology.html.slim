css:
    .methodology-page {
        color: #241f1a;
        display: flex;
        flex: 1;
        flex-direction: column;
        min-height: 100%;
        padding-bottom: 3.5rem;
    }

    .methodology-page .methodology-container {
        flex: 1;
        max-width: 980px;
    }

    .methodology-page .methodology-back-link {
        color: #8c1515;
        display: inline-block;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 1.75rem;
        text-decoration: none;
    }

    .methodology-page .methodology-back-link:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .methodology-page .methodology-hero {
        margin-bottom: 2rem;
    }

    .methodology-page .methodology-title {
        color: #2b2926;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.05;
        margin-bottom: 0.65rem;
    }

    .methodology-page .methodology-lead {
        color: #3f3933;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.08rem;
        line-height: 1.65;
        margin: 0;
    }

    .methodology-page .methodology-section {
        margin-bottom: 2.75rem;
    }

    .methodology-page .methodology-section-label {
        color: #8b8379;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        margin-bottom: 0.85rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-section-intro {
        color: #3f3933;
        font-size: 0.94rem;
        line-height: 1.65;
        margin: 0 0 1rem;
    }

    .methodology-page .methodology-table-wrap {
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        overflow-x: auto;
    }

    .methodology-page .methodology-table {
        border-collapse: collapse;
        font-size: 0.88rem;
        line-height: 1.5;
        margin: 0;
        min-width: 640px;
        width: 100%;
    }

    .methodology-page .methodology-table th {
        background: #f0ebe3;
        border-bottom: 1px solid #e1dccf;
        color: #2b2926;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.06em;
        padding: 0.75rem 1rem;
        text-align: left;
        text-transform: uppercase;
        vertical-align: top;
    }

    .methodology-page .methodology-table td {
        border-bottom: 1px solid #ece7de;
        color: #3f3933;
        padding: 0.85rem 1rem;
        vertical-align: top;
    }

    .methodology-page .methodology-table tbody tr:last-child td {
        border-bottom: none;
    }

    .methodology-page .methodology-table .field-name {
        color: #2b2926;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.82rem;
        font-weight: 600;
        white-space: nowrap;
    }

    .methodology-page .methodology-table .field-type {
        color: #6b645b;
        font-size: 0.82rem;
        white-space: nowrap;
    }

    .methodology-page .methodology-table .category-name {
        color: #2b2926;
        font-weight: 700;
        min-width: 11rem;
    }

    .methodology-page .methodology-table .category-count {
        color: #6b645b;
        font-size: 0.82rem;
        text-align: right;
        white-space: nowrap;
    }

    .methodology-page .methodology-table .category-count-note {
        color: #8b8379;
        font-size: 0.72rem;
        font-weight: 600;
        margin-left: 0.25rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-table .category-status {
        color: #6b645b;
        font-size: 0.82rem;
        white-space: nowrap;
    }

    .methodology-page .methodology-planned-label {
        color: #8c1515;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-left: 0.5rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-table th.text-end,
    .methodology-page .methodology-table td.text-end {
        text-align: right;
    }

    .methodology-page .methodology-group-label {
        background: rgba(240, 235, 227, 0.55);
        color: #6b645b;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        padding: 0.55rem 1rem;
        text-transform: uppercase;
    }

    .methodology-page .methodology-principle-box {
        background: #f0ebe3;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        color: #3f3933;
        font-size: 0.92rem;
        line-height: 1.65;
        margin-bottom: 1.25rem;
        padding: 1rem 1.15rem;
    }

    .methodology-page .methodology-principle-box p {
        margin: 0;
    }

    .methodology-page .methodology-accordion .accordion-item {
        background: transparent;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        margin-bottom: 0.75rem;
        overflow: hidden;
    }

    .methodology-page .methodology-accordion .accordion-item:last-child {
        margin-bottom: 0;
    }

    .methodology-page .methodology-accordion .accordion-button {
        background: #f0ebe3;
        box-shadow: none;
        color: #2b2926;
        font-size: 0.92rem;
        font-weight: 700;
        padding: 0.85rem 1rem;
    }

    .methodology-page .methodology-accordion .accordion-button:not(.collapsed) {
        background: #f0ebe3;
        color: #8c1515;
    }

    .methodology-page .methodology-accordion .accordion-button:focus {
        box-shadow: none;
    }

    .methodology-page .methodology-accordion .accordion-body {
        padding: 0;
    }

    .methodology-page .methodology-accordion .methodology-table-wrap {
        border: none;
        border-radius: 0;
    }

    .methodology-page .methodology-link {
        color: #8c1515;
        font-weight: 600;
        text-decoration: none;
    }

    .methodology-page .methodology-link:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .methodology-page .methodology-reference-list {
        border-top: 1px solid #e1dccf;
    }

    .methodology-page .methodology-reference-row {
        align-items: start;
        border-bottom: 1px solid #e1dccf;
        display: grid;
        gap: 0.85rem;
        grid-template-columns: 2rem minmax(0, 1fr) 1.25rem;
        padding: 0.95rem 0;
    }

    .methodology-page .methodology-reference-icon {
        align-items: center;
        background: #ece7da;
        border-radius: 0.55rem;
        display: flex;
        height: 2rem;
        justify-content: center;
        width: 2rem;
    }

    .methodology-page .methodology-reference-text {
        color: #3f3933;
        font-size: 0.92rem;
        line-height: 1.6;
    }

    .methodology-page .methodology-reference-index {
        color: #8c1515;
        font-weight: 700;
        margin-right: 0.35rem;
    }

    .methodology-page .methodology-reference-copy {
        align-items: center;
        background: transparent;
        border: 0;
        color: #b7afa4;
        cursor: pointer;
        display: flex;
        font-size: 0.82rem;
        height: 1.25rem;
        justify-content: center;
        justify-self: end;
        line-height: 1;
        margin-top: 0.15rem;
        padding: 0;
        width: 1.25rem;
    }

    .methodology-page .methodology-reference-copy:hover {
        color: #8c1515;
    }

    .methodology-page .methodology-reference-copy.is-copied {
        color: #047857;
    }

- content_for :title, "Data Methodology & Dictionary"
- content_for :description, "Data dictionary, classification scheme, and statistics conventions for the Stanford CodeX TechIndex legal technology index."
- category_rows = methodology_category_rows
- company_count = visible_company_count

.methodology-page
    .container.methodology-container.py-4.py-lg-5
        = link_to statistics_path, class: "methodology-back-link" do
            | ← All statistics

        header.methodology-hero
            h1.methodology-title Data Methodology & Dictionary
            p.methodology-lead How the TechIndex defines legal technology company profiles, classification, and statistics.

        section.methodology-section#methodology-overview
            .methodology-section-label Overview
            .methodology-principle-box
                p== methodology_overview_html(number_with_delimiter(company_count))

        section.methodology-section#methodology-eligibility
            .methodology-section-label What is a legal technology company?
            p.methodology-section-intro= methodology_eligibility_guidance

        section.methodology-section#methodology-profiles
            .methodology-section-label Company profiles
            p.methodology-section-intro= methodology_category_guidance
            .accordion.methodology-accordion.mt-3 id="methodologyProfiles"
                .accordion-item
                    h2.accordion-header id="profileFieldsHeading"
                        button.accordion-button.collapsed type="button" data-bs-toggle="collapse" data-bs-target="#profileFieldsCollapse" aria-expanded="false" aria-controls="profileFieldsCollapse" Company profile fields
                    #profileFieldsCollapse.accordion-collapse.collapse aria-labelledby="profileFieldsHeading" data-bs-parent="#methodologyProfiles"
                        .accordion-body
                            .methodology-table-wrap
                                table.methodology-table
                                    thead
                                        tr
                                            th Field
                                            th Type
                                            th Description
                                    tbody
                                        - methodology_company_field_groups.each do |group|
                                            tr
                                                td.methodology-group-label colspan="3"= group[:label]
                                            - group[:fields].each do |field|
                                                tr
                                                    td
                                                        span.field-name= field[:name]
                                                    td.field-type= field[:type]
                                                    td= field[:description]
                .accordion-item
                    h2.accordion-header id="primaryCategoriesHeading"
                        button.accordion-button.collapsed type="button" data-bs-toggle="collapse" data-bs-target="#primaryCategoriesCollapse" aria-expanded="false" aria-controls="primaryCategoriesCollapse" Primary categories (12)
                    #primaryCategoriesCollapse.accordion-collapse.collapse aria-labelledby="primaryCategoriesHeading" data-bs-parent="#methodologyProfiles"
                        .accordion-body
                            .methodology-table-wrap
                                table.methodology-table
                                    thead
                                        tr
                                            th Category
                                            th Definition
                                            th.text-end Count
                                    tbody
                                        - category_rows.each do |row|
                                            tr
                                                td.category-name= row[:name]
                                                td= row[:definition]
                                                td.category-count.text-end= number_with_delimiter(row[:count])
                .accordion-item
                    h2.accordion-header id="revenueModelsHeading"
                        button.accordion-button.collapsed type="button" data-bs-toggle="collapse" data-bs-target="#revenueModelsCollapse" aria-expanded="false" aria-controls="revenueModelsCollapse" Revenue models
                    #revenueModelsCollapse.accordion-collapse.collapse aria-labelledby="revenueModelsHeading" data-bs-parent="#methodologyProfiles"
                        .accordion-body
                            p.methodology-section-intro.px-3.pt-3= methodology_revenue_model_guidance
                            .methodology-table-wrap
                                table.methodology-table
                                    thead
                                        tr
                                            th Model
                                            th Definition
                                    tbody
                                        - methodology_revenue_models.each do |row|
                                            tr
                                                td.category-name= row[:name]
                                                td= row[:definition]
                .accordion-item
                    h2.accordion-header id="targetClientsHeading"
                        button.accordion-button.collapsed type="button" data-bs-toggle="collapse" data-bs-target="#targetClientsCollapse" aria-expanded="false" aria-controls="targetClientsCollapse" Target clients
                    #targetClientsCollapse.accordion-collapse.collapse aria-labelledby="targetClientsHeading" data-bs-parent="#methodologyProfiles"
                        .accordion-body
                            p.methodology-section-intro.px-3.pt-3 A company may serve one or more of these audiences.
                            .methodology-table-wrap
                                table.methodology-table
                                    thead
                                        tr
                                            th Value
                                            th Definition
                                    tbody
                                        - methodology_target_clients.each do |row|
                                            tr
                                                td.category-name= row[:name]
                                                td= row[:definition]
                .accordion-item
                    h2.accordion-header id="tagsHeading"
                        button.accordion-button.collapsed type="button" data-bs-toggle="collapse" data-bs-target="#tagsCollapse" aria-expanded="false" aria-controls="tagsCollapse" Tags
                    #tagsCollapse.accordion-collapse.collapse aria-labelledby="tagsHeading" data-bs-parent="#methodologyProfiles"
                        .accordion-body
                            p.methodology-section-intro.px-3.pt-3.pb-3= methodology_tags_guidance

        section.methodology-section#methodology-statistics
            .methodology-section-label Statistics
            p.methodology-section-intro= methodology_statistics_guidance

        section.methodology-section#methodology-citations
            .methodology-section-label Citations
            p.methodology-section-intro= methodology_citations_guidance
            .methodology-reference-list
                - methodology_citation_entries.each_with_index do |entry, index|
                    .methodology-reference-row
                        .methodology-reference-icon
                            i class="#{entry[:icon]}" style="color: #{entry[:icon_color]};"
                        .methodology-reference-text
                            span.methodology-reference-index= "[#{index + 1}]"
                            = entry[:citation]
                        button.methodology-reference-copy type="button" aria-label="Copy citation #{index + 1}" title="Copy citation" data-citation-copy="true" data-citation=entry[:citation]
                            i.fa-regular.fa-copy aria-hidden="true"

= render "shared/citation_copy_script"
