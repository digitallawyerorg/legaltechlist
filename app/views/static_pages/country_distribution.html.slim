- content_for :title, "Companies by Country"
- content_for :description, "Geographic concentration of legal tech companies by country, based on visible CodeX TechIndex profiles founded since 2000."
- chart_id = "country-distribution-chart"
- geo_library = { backgroundColor: "#ffffff", datalessRegionColor: "#f8f9fa", defaultColor: "#f8f9fa", colorAxis: { minValue: 0, maxValue: @geo_map_max, colors: ["#f3e1e1", "#8c1515"] }, tooltip: { isHtml: false }, region: "world", displayMode: "regions", resolution: "countries" }
- chart_html = render partial: "shared/stats_country_geo_map", locals: { chart_id: chart_id, chart_data: @chart_data, library: geo_library }
= render partial: "shared/stats_chart_page", locals: { title: "Companies by Country", chart: chart_html, table: render(partial: "shared/data_table", locals: { headers: ["Country", "Companies", "Total Funding", "Avg Funding"], rows: @table_data.map { |data| [data[:country], data[:companies], number_to_currency(data[:total_funding], precision: 0), number_to_currency(data[:avg_funding], precision: 0)] } }), chart_id: chart_id, download_filename: "country_distribution", csv_path: statistics_country_distribution_path(format: :csv), xlsx_path: statistics_country_distribution_path(format: :xlsx), table_title: "Country breakdown", show_funding_caveat: true }
