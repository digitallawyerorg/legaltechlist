.bg-body.border-bottom
  .container.py-4
      .col-12
        = render partial: 'shared/statistics_card', locals: { title: "Category Growth Trends", subtitle: "Annual company formation by category", chart: line_chart(@table_data.map { |d| { name: d[:category], data: d[:yearly_data] } }, height: "600px", colors: ["#8c1515", "#175e54", "#820000", "#b83a4b", "#544948", "#006b81", "#2e2d29", "#767676", "#53284f", "#8d3c1e"], library: { plugins: { legend: { position: 'bottom' } }, scales: { x: { grid: { display: true, drawBorder: false }, ticks: { font: { size: 12 } } }, y: { grid: { display: true, drawBorder: false }, ticks: { font: { size: 12 } } } } }, id: "category-evolution-chart"), table: render(partial: 'shared/data_table', locals: { headers: ['Category', 'Total Companies', 'Growth Rate', 'Market Share'], rows: @summary_data.map { |data| [data[:category], data[:total_companies], content_tag(:span, class: growth_rate_class(data[:growth_rate])) { growth_rate_content(data[:growth_rate]) }, "#{data[:market_share].round(1)}%"] } }), chart_id: "category-evolution-chart", download_filename: "category_evolution" }

