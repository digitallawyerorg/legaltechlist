- chart_id = "companies-founded-chart"
= render partial: "shared/statistics_card", locals: { title: "Companies Founded by Year", chart: column_chart(@table_data.map { |d| [d[:year], d[:new_companies]] }, height: 620, colors: ["#8c1515"], library: { plugins: { legend: { display: false } }, scales: { x: { grid: { display: true, drawBorder: false }, ticks: { font: { size: 12 } } }, y: { grid: { display: true, drawBorder: false }, ticks: { font: { size: 12 } } } } }, id: chart_id), table: render(partial: "shared/data_table", locals: { headers: ["Year", "New Companies", "Total Companies", "Growth Rate"], rows: @table_data.map { |data| [data[:year], data[:new_companies], data[:total_companies], content_tag(:span, class: growth_rate_class(data[:growth_rate])) { growth_rate_content(data[:growth_rate]) }] } }), chart_id: chart_id, download_filename: "companies_founded" }
