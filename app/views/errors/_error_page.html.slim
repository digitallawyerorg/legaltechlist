css:
    .error-page {
        color: #241f1a;
        display: flex;
        flex: 1;
        flex-direction: column;
        min-height: 100%;
        padding-bottom: 3.5rem;
    }

    .error-page .error-page-container {
        align-items: center;
        display: flex;
        flex: 1;
        justify-content: center;
    }

    .error-page .error-page-card {
        background: #fff;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        box-shadow: 0 10px 28px rgba(36, 31, 26, 0.06);
        max-width: 34rem;
        padding: 2.25rem 2rem 2rem;
        text-align: center;
        width: 100%;
    }

    .error-page .error-page-code {
        color: #8c1515;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.14em;
        margin: 0 0 0.85rem;
        text-transform: uppercase;
    }

    .error-page .error-page-title {
        color: #2b2926;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(1.65rem, 4vw, 2.1rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin: 0 0 0.85rem;
    }

    .error-page .error-page-message {
        color: #3f3933;
        font-size: 0.98rem;
        line-height: 1.65;
        margin: 0 auto 1.75rem;
        max-width: 28rem;
    }

    .error-page .error-page-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: center;
    }

    .error-page .error-page-action {
        align-items: center;
        border-radius: 0.65rem;
        display: inline-flex;
        font-size: 0.88rem;
        font-weight: 700;
        justify-content: center;
        min-height: 2.65rem;
        padding: 0.72rem 1.05rem;
        text-decoration: none;
    }

    .error-page .error-page-action-primary {
        background: #8c1515;
        border: 1px solid #8c1515;
        color: #fff;
    }

    .error-page .error-page-action-primary:hover {
        background: #6f1111;
        border-color: #6f1111;
        color: #fff;
        text-decoration: none;
    }

    .error-page .error-page-action-secondary {
        background: #fff;
        border: 1px solid #ded7ca;
        color: #3f3933;
    }

    .error-page .error-page-action-secondary:hover {
        background: #f0ebe3;
        border-color: #cfc7ba;
        color: #2b2926;
        text-decoration: none;
    }

- content_for :robots, "noindex"
- content_for :title, error[:title]

.error-page
    .container.error-page-container.py-4.py-lg-5
        .error-page-card
            p.error-page-code= error[:code]
            h1.error-page-title= error[:heading]
            p.error-page-message= error[:message]
            .error-page-actions
                = link_to "Back to homepage", root_path, class: "error-page-action error-page-action-primary"
                = link_to "Browse companies", companies_path, class: "error-page-action error-page-action-secondary"
