css:
    .company-suggest-page {
        color: #241f1a;
        display: flex;
        flex: 1;
        flex-direction: column;
        min-height: 100%;
        padding-bottom: 3.5rem;
    }

    .company-suggest-page .company-suggest-container {
        flex: 1;
        max-width: 760px;
    }

    .company-suggest-page .company-suggest-back-link {
        color: #8c1515;
        display: inline-block;
        font-size: 0.88rem;
        font-weight: 600;
        margin-bottom: 1.75rem;
        text-decoration: none;
    }

    .company-suggest-page .company-suggest-back-link:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .company-suggest-page .company-suggest-hero {
        margin-bottom: 2rem;
    }

    .company-suggest-page .company-suggest-title {
        color: #2b2926;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.05;
        margin-bottom: 0.65rem;
    }

    .company-suggest-page .company-suggest-lead {
        color: #3f3933;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.08rem;
        line-height: 1.65;
        margin: 0;
        max-width: 44rem;
    }

    .company-suggest-page .company-suggest-note {
        background: #f0ebe3;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        color: #3f3933;
        font-size: 0.94rem;
        line-height: 1.65;
        margin-bottom: 2rem;
        padding: 1rem 1.15rem;
    }

    .company-suggest-page .company-suggest-note a {
        color: #8c1515;
        font-weight: 600;
        text-decoration: none;
    }

    .company-suggest-page .company-suggest-note a:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .company-suggest-page .company-suggest-flash {
        border-radius: 0.75rem;
        font-size: 0.92rem;
        line-height: 1.5;
        margin-bottom: 1.25rem;
        padding: 0.85rem 1rem;
    }

    .company-suggest-page .company-suggest-flash.notice {
        background: #eef6f0;
        border: 1px solid #c8e6d0;
        color: #1f5130;
    }

    .company-suggest-page .company-suggest-flash.alert {
        background: #fdf0ef;
        border: 1px solid #efc9c5;
        color: #7a1f18;
    }

    .company-suggest-page .company-suggest-section {
        margin-bottom: 2rem;
    }

    .company-suggest-page .company-suggest-section-label {
        color: #8b8379;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        margin-bottom: 0.85rem;
        text-transform: uppercase;
    }

    .company-suggest-page .company-suggest-panel {
        background: #fff;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        padding: 1.25rem 1.15rem;
    }

    .company-suggest-page .company-suggest-form .form-label {
        color: #2b2926;
        font-size: 0.88rem;
        font-weight: 700;
        margin-bottom: 0.35rem;
    }

    .company-suggest-page .company-suggest-form .form-text {
        color: #6b645b;
        font-size: 0.82rem;
    }

    .company-suggest-page .company-suggest-form .form-control,
    .company-suggest-page .company-suggest-form .form-select {
        background: rgba(255, 255, 255, 0.92);
        border-color: #ded7ca;
        border-radius: 0.55rem;
        font-size: 0.92rem;
        min-height: 2.65rem;
    }

    .company-suggest-page .company-suggest-form .form-control:focus,
    .company-suggest-page .company-suggest-form .form-select:focus {
        border-color: #cbbfae;
        box-shadow: 0 0 0 0.15rem rgba(140, 21, 21, 0.08);
    }

    .company-suggest-page .company-suggest-form textarea.form-control {
        min-height: 7rem;
    }

    .company-suggest-page .company-suggest-form .input-group-text {
        background: #f0ebe3;
        border-color: #ded7ca;
        color: #6b645b;
    }

    .company-suggest-page .company-suggest-actions {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        justify-content: flex-end;
        margin-top: 0.5rem;
    }

    .company-suggest-page .company-suggest-submit {
        background: #8c1515;
        border: 1px solid #8c1515;
        border-radius: 0.55rem;
        color: #fff;
        font-size: 0.92rem;
        font-weight: 700;
        min-height: 2.65rem;
        padding: 0.45rem 1.35rem;
    }

    .company-suggest-page .company-suggest-submit:hover {
        background: #6f1111;
        border-color: #6f1111;
        color: #fff;
    }

    .company-suggest-page .company-suggest-cancel {
        border: 1px solid #ded7ca;
        border-radius: 0.55rem;
        color: #4b5563;
        font-size: 0.92rem;
        font-weight: 600;
        min-height: 2.65rem;
        padding: 0.45rem 1.15rem;
        text-decoration: none;
    }

    .company-suggest-page .company-suggest-cancel:hover {
        background: #f6f1e7;
        color: #111827;
    }

    .company-suggest-page .company-suggest-errors {
        background: #fdf0ef;
        border: 1px solid #efc9c5;
        border-radius: 0.85rem;
        color: #7a1f18;
        margin-bottom: 1.5rem;
        padding: 1rem 1.15rem;
    }

    .company-suggest-page .company-suggest-errors h2 {
        font-size: 0.95rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }

    .company-suggest-page .company-suggest-errors ul {
        margin-bottom: 0;
        padding-left: 1.15rem;
    }

    @media (max-width: 640px) {
        .company-suggest-page .company-suggest-actions {
            flex-direction: column;
            width: 100%;
        }

        .company-suggest-page .company-suggest-submit,
        .company-suggest-page .company-suggest-cancel {
            width: 100%;
        }
    }

.company-suggest-page
    .container.company-suggest-container.py-4.py-lg-5
        = link_to companies_path, class: "company-suggest-back-link" do
            | ← All companies

        header.company-suggest-hero
            h1.company-suggest-title= title
            p.company-suggest-lead= lead

        .company-suggest-note
            p.mb-0
                | Submissions are reviewed before publication. We list companies — market-facing vendors — not individual products.
                = link_to " See how we classify companies", statistics_methodology_path

        - if notice.present?
            .company-suggest-flash.notice= notice
        - if alert.present?
            .company-suggest-flash.alert= alert
        - flash.each do |type, message|
            - next if message.blank?
            - flash_class = (type.to_s == "alert" ? "alert" : "notice")
            .company-suggest-flash class=flash_class
                = message

        = render "form"
