css:
    .company-show-page {
        color: #241f1a;
        display: flex;
        flex: 1;
        flex-direction: column;
        min-height: 100%;
        padding-bottom: 3.5rem;
    }

    .company-show-page .company-show-container {
        flex: 1;
        max-width: 920px;
        padding-top: clamp(0.75rem, 1.75vw, 1rem);
    }

    .company-show-page .company-show-nav {
        align-items: center;
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        margin-bottom: 0.85rem;
    }

    .company-show-page .company-show-nav-link {
        align-items: center;
        color: rgba(42, 39, 35, 0.68);
        display: inline-flex;
        font-size: 0.875rem;
        font-weight: 500;
        gap: 0.45rem;
        line-height: 1.25;
        max-width: min(48%, 26rem);
        min-width: 0;
        text-decoration: none;
    }

    .company-show-page .company-show-nav-link:hover {
        color: #8c1515;
        text-decoration: none;
    }

    .company-show-page .company-show-nav-prev {
        justify-content: flex-start;
    }

    .company-show-page .company-show-nav-next {
        justify-content: flex-end;
        margin-left: auto;
    }

    .company-show-page .company-show-nav-spacer {
        flex: 1;
        min-width: 0;
    }

    .company-show-page .company-show-nav-icon {
        color: rgba(42, 39, 35, 0.42);
        flex-shrink: 0;
        font-size: 0.72rem;
    }

    .company-show-page .company-show-nav-link:hover .company-show-nav-icon {
        color: #8c1515;
    }

    .company-show-page .company-show-nav-title {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .company-show-page .company-hero {
        align-items: flex-start;
        border-top: 1px solid #e1dccf;
        display: flex;
        gap: 1.25rem;
        justify-content: space-between;
        padding-bottom: 1.25rem;
        padding-top: 1.25rem;
    }

    .company-show-page .company-hero-actions {
        flex: 0 0 auto;
        padding-top: 0.15rem;
    }

    .company-show-page .company-suggest-update-btn {
        align-items: center;
        background: #fff;
        border: 1px solid #e1dccf;
        border-radius: 999px;
        color: #2b2926;
        cursor: pointer;
        display: inline-flex;
        font-size: 0.88rem;
        font-weight: 600;
        gap: 0.45rem;
        padding: 0.55rem 0.95rem;
        text-decoration: none;
        transition: background 0.12s ease, border-color 0.12s ease, color 0.12s ease;
        white-space: nowrap;
    }

    .company-show-page .company-suggest-update-btn:hover {
        background: #faf8f4;
        border-color: #d4cec0;
        color: #2b2926;
        text-decoration: none;
    }

    .company-show-page .company-suggest-update-btn-icon {
        color: #6b6258;
        font-size: 0.82rem;
    }

    .company-show-page .company-hero-main {
        align-items: flex-start;
        display: flex;
        flex: 1;
        gap: 1.25rem;
        min-width: 0;
    }

    .company-show-page .company-logo-frame {
        align-items: center;
        background: #fce8e8;
        border: 1px solid rgba(140, 21, 21, 0.12);
        border-radius: 0.85rem;
        display: flex;
        flex: 0 0 4.5rem;
        height: 4.5rem;
        justify-content: center;
        overflow: hidden;
        width: 4.5rem;
    }

    .company-show-page .company-logo-placeholder {
        color: #8c1515;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.75rem;
        font-weight: 700;
    }

    .company-show-page .company-logo-image {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 0.85rem;
        display: block;
        flex: 0 0 4.5rem;
        height: 4.5rem;
        object-fit: contain;
        padding: 0.5rem;
        width: 4.5rem;
    }

    .company-show-page .company-show-title {
        color: #2b2926;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.05;
        margin-bottom: 0;
    }

    .company-show-page .company-hero-website {
        align-items: center;
        color: #8c1515;
        display: inline-flex;
        font-size: 0.88rem;
        font-weight: 600;
        gap: 0.4rem;
        margin-top: 0.55rem;
        text-decoration: none;
    }

    .company-show-page .company-hero-website:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .company-show-page .company-hero-website:hover .company-hero-website-icon {
        color: #8c1515;
    }

    .company-show-page .company-hero-website-icon {
        color: #b7afa4;
        font-size: 0.82rem;
        line-height: 1;
    }

    .company-show-page .company-hero-website-inactive {
        color: #9a9288;
        cursor: default;
        font-weight: 600;
    }

    .company-show-page .company-status-note {
        background: #f0ebe3;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        color: #3f3933;
        font-size: 0.94rem;
        line-height: 1.65;
        margin-bottom: 1.75rem;
        padding: 1rem 1.15rem;
    }

    .company-show-page .company-status-note a {
        color: #8c1515;
        font-weight: 600;
        text-decoration: none;
    }

    .company-show-page .company-status-note a:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    .company-show-page .company-about-tags {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem 0.85rem;
        margin-top: 1rem;
    }

    .company-show-page .company-about-category {
        align-items: center;
        background: #f3e2e2;
        border-radius: 999px;
        color: #8c1515;
        display: inline-flex;
        font-size: 0.78rem;
        font-weight: 600;
        gap: 0.45rem;
        padding: 0.42rem 0.75rem;
    }

    .company-show-page .company-about-category-dot {
        background: #8c1515;
        border-radius: 999px;
        flex: 0 0 0.4rem;
        height: 0.4rem;
        width: 0.4rem;
    }

    .company-show-page .company-about-keyword {
        background: #ece7da;
        border-radius: 999px;
        color: #8a857a;
        display: inline-flex;
        font-size: 0.78rem;
        font-weight: 400;
        padding: 0.38rem 0.7rem;
        text-decoration: none;
    }

    .company-show-page a.company-about-keyword:hover {
        background: #e6e1d5;
        color: #6f6a60;
    }

    .company-show-page .company-about-section {
        border-top: 1px solid #e1dccf;
        padding-top: 1.25rem;
    }

    .company-show-page .company-section {
        margin-bottom: 2.5rem;
    }

    .company-show-page .company-section-label {
        color: #8b8379;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        margin-bottom: 0.85rem;
        text-transform: uppercase;
    }

    .company-show-page .company-key-facts-list {
        display: grid;
        gap: 0.85rem;
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .company-show-page .company-key-fact-card {
        align-items: center;
        background: #f0ebe3;
        border: 1px solid #e1dccf;
        border-radius: 0.85rem;
        display: flex;
        gap: 0.85rem;
        padding: 1rem 1.1rem;
    }

    .company-show-page .company-key-fact-icon {
        align-items: center;
        background: #ece7da;
        border: 0;
        border-radius: 0.55rem;
        color: #6b6258;
        display: flex;
        flex: 0 0 2.35rem;
        height: 2.35rem;
        justify-content: center;
        width: 2.35rem;
    }

    .company-show-page .company-key-fact-icon i {
        font-size: 0.82rem;
    }

    .company-show-page .company-key-fact-copy {
        min-width: 0;
    }

    .company-show-page .company-key-fact-label {
        color: #8b8379;
        font-size: 0.68rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        margin-bottom: 0.2rem;
        text-transform: uppercase;
    }

    .company-show-page .company-key-fact-value {
        color: #2b2926;
        font-size: 0.98rem;
        font-weight: 700;
        line-height: 1.25;
    }

    .company-show-page .company-show-body {
        color: #3f3933;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.08rem;
        line-height: 1.75;
        margin-bottom: 0;
    }

    .company-show-page .company-source-list {
        border-top: 1px solid #e1dccf;
    }

    .company-show-page .company-source-row {
        align-items: center;
        border-bottom: 1px solid #e1dccf;
        color: inherit;
        display: grid;
        gap: 0.85rem;
        grid-template-columns: 2rem 7.5rem minmax(0, 1fr) 1.25rem;
        padding: 0.95rem 0;
        text-decoration: none;
    }

    .company-show-page .company-source-row:hover {
        color: inherit;
    }

    .company-show-page .company-source-row:hover .company-source-label {
        color: #8c1515;
    }

    .company-show-page .company-source-row-inactive {
        cursor: default;
    }

    .company-show-page .company-source-row-inactive:hover .company-source-label {
        color: #241f1a;
    }

    .company-show-page .company-source-inactive-dot {
        background: #dc2626;
        border-radius: 999px;
        display: block;
        height: 0.45rem;
        width: 0.45rem;
    }

    .company-show-page .company-source-icon {
        align-items: center;
        background: #ece7da;
        border: 0;
        border-radius: 0.55rem;
        display: flex;
        height: 2rem;
        justify-content: center;
        width: 2rem;
    }

    .company-show-page .company-source-icon i {
        font-size: 0.82rem;
    }

    .company-show-page .company-source-label {
        color: #241f1a;
        font-size: 0.92rem;
        font-weight: 700;
    }

    .company-show-page .company-source-host {
        color: #9a9288;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: 0.82rem;
        justify-self: start;
    }

    .company-show-page .company-source-arrow {
        color: #b7afa4;
        font-size: 0.82rem;
        justify-self: end;
        line-height: 1;
    }

    .company-show-page .company-reference-list {
        border-top: 1px solid #e1dccf;
    }

    .company-show-page .company-reference-row {
        align-items: start;
        border-bottom: 1px solid #e1dccf;
        display: grid;
        gap: 0.85rem;
        grid-template-columns: 2rem minmax(0, 1fr) 1.25rem;
        padding: 0.95rem 0;
    }

    .company-show-page .company-reference-text {
        color: #3f3933;
        font-size: 0.92rem;
        line-height: 1.6;
    }

    .company-show-page .company-reference-index {
        color: #8c1515;
        font-weight: 700;
        margin-right: 0.35rem;
    }

    .company-show-page .company-reference-copy {
        align-items: center;
        background: transparent;
        border: 0;
        color: #b7afa4;
        cursor: pointer;
        display: flex;
        font-size: 0.82rem;
        height: 1.25rem;
        justify-content: center;
        justify-self: end;
        line-height: 1;
        margin-top: 0.15rem;
        padding: 0;
        width: 1.25rem;
    }

    .company-show-page .company-reference-copy:hover {
        color: #8c1515;
    }

    .company-show-page .company-reference-copy.is-copied {
        color: #047857;
    }

    .company-show-page .company-citation-header {
        align-items: center;
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        margin-bottom: 0.75rem;
    }

    .company-show-page .company-citation-box {
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid rgba(36, 31, 26, 0.08);
        border-radius: 0.85rem;
        color: #3f3933;
        font-size: 0.92rem;
        line-height: 1.65;
        padding: 1rem 1.15rem;
    }

    .company-show-page .company-related-grid {
        display: grid;
        gap: 0.85rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .company-show-page .company-related-card {
        align-items: flex-start;
        background: #fff;
        border: 1px solid rgba(36, 31, 26, 0.1);
        border-radius: 0.85rem;
        color: inherit;
        display: flex;
        gap: 0.8rem;
        padding: 0.95rem;
        text-decoration: none;
    }

    .company-show-page .company-related-card:hover {
        border-color: rgba(140, 21, 21, 0.25);
        color: inherit;
    }

    .company-show-page .company-related-avatar {
        align-items: center;
        border-radius: 0.55rem;
        color: #1f2937;
        display: flex;
        flex: 0 0 2.35rem;
        font-size: 0.95rem;
        font-weight: 700;
        height: 2.35rem;
        justify-content: center;
        width: 2.35rem;
    }

    .company-show-page .company-related-name {
        color: #241f1a;
        font-size: 0.92rem;
        font-weight: 700;
        line-height: 1.25;
        margin-bottom: 0.15rem;
    }

    .company-show-page .company-related-category {
        color: #8b8379;
        font-size: 0.78rem;
        line-height: 1.35;
    }

    .company-show-page .company-maintainer-note {
        border-top: 1px solid rgba(36, 31, 26, 0.08);
        color: #8b8379;
        font-size: 0.78rem;
        margin-top: 1rem;
        padding-top: 1.5rem;
    }

    .company-show-page .company-maintainer-note a {
        color: #8c1515;
        text-decoration: none;
    }

    .company-show-page .company-maintainer-note a:hover {
        text-decoration: underline;
    }

    @media (max-width: 767.98px) {
        .company-show-page .company-hero {
            flex-direction: column;
        }

        .company-show-page .company-hero-actions {
            padding-top: 0;
            width: 100%;
        }

        .company-show-page .company-suggest-update-btn {
            justify-content: center;
            width: 100%;
        }

        .company-show-page .company-key-facts-list {
            grid-template-columns: 1fr;
        }

        .company-show-page .company-related-grid {
            grid-template-columns: 1fr;
        }

        .company-show-page .company-show-nav {
            gap: 0.5rem;
            margin-bottom: 0.65rem;
        }

        .company-show-page .company-show-nav-link {
            font-size: 0.8rem;
            gap: 0.3rem;
            max-width: 49%;
        }

        .company-show-page .company-source-row {
            gap: 0.65rem;
            grid-template-columns: 2rem 5.5rem minmax(0, 1fr) 1.25rem;
        }

        .company-show-page .company-reference-row {
            gap: 0.65rem;
            grid-template-columns: 2rem minmax(0, 1fr) 1.25rem;
        }
    }

- website_url = (@company.main_url.present? && @company.main_url != "n/a") ? (@company.main_url.include?("http") ? @company.main_url : "http://#{@company.main_url}") : nil
- company_inactive = company_inactive?(@company)
- inactive_company_tooltip = CompaniesHelper::INACTIVE_COMPANY_TOOLTIP
- content_for :title, @company.name
- content_for :description, truncate(@company.description.to_s, length: 160)
- content_for :json_ld, company_organization_json_ld(@company)
- twitter_url = (@company.twitter_url.present? && @company.twitter_url != "n/a") ? (@company.twitter_url.include?("@") ? "https://twitter.com/#{@company.twitter_url[1..-1]}" : @company.twitter_url) : nil
- status_label = @company.status.present? ? @company.status.titleize : "Unknown"
- exit_display = @company.exit_date.present? ? @company.exit_date.strftime("%B %Y") : nil
- show_entity_notice = @company.status.to_s.downcase.in?(%w[acquired inactive]) || @company.successor_company.present? || exit_display.present?
- entity_messages = []
- entity_messages << "This company has been acquired." if @company.status.to_s.downcase == "acquired"
- entity_messages << "This company is no longer active as an independent vendor." if @company.status.to_s.downcase == "inactive"
- entity_messages << "Exit recorded #{exit_display}." if exit_display.present?
- short_host_for = ->(url) { normalized = url.to_s.strip; normalized = "http://#{normalized}" unless normalized.match?(%r{\Ahttps?://}i); URI.parse(normalized).host.to_s.sub(/\Awww\./i, '') rescue url.to_s.gsub(%r{\Ahttps?://(www\.)?}i, '').split('/').first.to_s }
- funding_amount = @company.total_funding_amount_usd.to_f
- funding_display = (if funding_amount >= 1_000_000_000 then "$#{(funding_amount / 1_000_000_000).round(1).to_s.sub(/\.0$/, '')}B" elsif funding_amount >= 1_000_000 then "$#{(funding_amount / 1_000_000).round}M" elsif funding_amount.positive? then number_to_currency(funding_amount, precision: 0) else nil end)
- founded_display = (@company.founded_date.present? && @company.founded_date != "0000") ? @company.founded_date : "-"
- headquarters_display = (@company.display_location.present? && @company.display_location != "Nowhere") ? company_display_location(@company) : "-"
- target_market_names = (@company.target_clients.any? ? @company.target_clients : Array(@company.target_client).compact).map(&:name).uniq.reject { |name| name.blank? || name == "Unknown" }
- target_market_display = target_market_names.any? ? target_market_names.to_sentence : "-"
- revenue_model_names = @company.revenue_model_names.reject { |name| name.blank? || name == "Unknown" }
- revenue_model_display = revenue_model_names.any? ? revenue_model_names.to_sentence : "-"
- key_facts = [{ label: "Status", icon: "fa-solid fa-circle-check", value: status_label }, { label: "Founded", icon: "fa-regular fa-calendar", value: founded_display }, { label: "Headquarters", icon: "fa-solid fa-location-dot", value: headquarters_display }, { label: "Target market", icon: "fa-solid fa-bullseye", value: target_market_display }, { label: "Revenue model", icon: "fa-solid fa-coins", value: revenue_model_display }, { label: "Total funding", icon: "fa-solid fa-dollar-sign", value: funding_display.presence || "-" }]
- key_facts << { label: "Exit", icon: "fa-solid fa-flag-checkered", value: exit_display } if exit_display.present?
- company_reference_links = []
- company_reference_links << { label: "Facebook", icon: "fa-brands fa-facebook", icon_color: "#1877f2", url: @company.facebook_url, host: short_host_for.call(@company.facebook_url) } if @company.facebook_url.present? && @company.facebook_url != "n/a"
- company_reference_links << { label: "LinkedIn", icon: "fa-brands fa-linkedin", icon_color: "#0a66c2", url: @company.linkedin_url, host: short_host_for.call(@company.linkedin_url) } if @company.linkedin_url.present? && @company.linkedin_url != "n/a"
- company_reference_links << { label: "Website", icon: "fa-solid fa-globe", icon_color: "#2563eb", url: website_url, host: short_host_for.call(website_url) } if website_url.present?
- company_reference_links << { label: "X/Twitter", icon: "fa-brands fa-x-twitter", icon_color: "#111827", url: twitter_url, host: short_host_for.call(twitter_url) } if twitter_url.present?
- external_reference_links = []
- external_reference_links << { label: "Crunchbase", icon: "fa-solid fa-chart-line", icon_color: "#047857", url: @company.crunchbase_url, host: short_host_for.call(@company.crunchbase_url) } if @company.crunchbase_url.present? && @company.crunchbase_url != "n/a"
- external_reference_links << { label: "Legal.io", icon: "fa-solid fa-briefcase", icon_color: "#8c1515", url: @company.legalio_url, host: short_host_for.call(@company.legalio_url) } if @company.legalio_url.present? && @company.legalio_url != "n/a"
- atlas_reference = company_legaltech_atlas_reference(@company)
- external_reference_links << atlas_reference if atlas_reference.present?
- reference_sections = []
- reference_sections << { title: "Company references", links: company_reference_links } if company_reference_links.any?
- reference_sections << { title: "External references", links: external_reference_links } if external_reference_links.any?
- accessed_on = Date.current.strftime("%B %-d, %Y")
- academic_ref_entries = []
- academic_ref_entries << { icon: "fa-solid fa-globe", icon_color: "#2563eb", citation: "#{@company.name}. \"#{@company.name}.\" Official website. #{website_url} (accessed #{accessed_on})." } if website_url.present?
- academic_ref_entries << { icon: "fa-brands fa-linkedin", icon_color: "#0a66c2", citation: "#{@company.name}. LinkedIn company profile. #{@company.linkedin_url} (accessed #{accessed_on})." } if @company.linkedin_url.present? && @company.linkedin_url != "n/a"
- academic_ref_entries << { icon: "fa-solid fa-chart-line", icon_color: "#047857", citation: "#{@company.name}. Crunchbase company profile. #{@company.crunchbase_url} (accessed #{accessed_on})." } if @company.crunchbase_url.present? && @company.crunchbase_url != "n/a"
- atlas_record_url = @company.source_url.presence || company_url(@company)
- academic_ref_entries << { icon: "fa-solid fa-book", icon_color: "#8c1515", citation: "#{@company.name}. #{@company.source} record. #{atlas_record_url} (accessed #{accessed_on})." } if @company.source.present?
- reviewed_at = @company.human_reviewed_at || @company.quality_reviewed_at || @company.updated_at
- reviewed_label = reviewed_at.strftime("%B %Y")
- citation_text = "Stanford Center for Legal Informatics (CodeX), CodeX TechIndex, #{@company.name}, #{company_url(@company)} (last visited #{accessed_on})."
- related_avatar_colors = ["#dbeafe", "#fce7f3", "#dcfce7", "#fef3c7", "#ede9fe"]

.company-show-page
    .container.company-show-container.pb-4.pb-lg-5
        - if flash[:notice]
            .alert.alert-success.mb-4= flash[:notice]
        - if flash[:alert]
            .alert.alert-danger.mb-4= flash[:alert]

        = render partial: "companies/company_nav", locals: { neighbors: @company_neighbors, nav_context: @companies_nav_context }

        - if show_entity_notice
            .company-status-note
                p.mb-0= entity_messages.join(" ")
                - if @company.successor_company.present?
                    p.mb-0.mt-2
                        | Current record:
                        = link_to @company.successor_company.name, company_path(@company.successor_company)

        .company-hero
            .company-hero-main
                - if @company.logo_placeholder?
                    .company-logo-frame
                        .company-logo-placeholder= @company.name.to_s.first
                - else
                    = image_tag @company.logo, alt: "#{@company.name} logo", class: "company-logo-image"
                div
                    h1.company-show-title= @company.name
                    - if website_url.present?
                        - if company_inactive
                            span.company-hero-website.company-hero-website-inactive title=inactive_company_tooltip
                                = website_display_label(@company.main_url)
                        - else
                            = link_to website_url, class: "company-hero-website", target: "_blank", rel: "noopener" do
                                = website_display_label(@company.main_url)
                                i.fa-solid.fa-arrow-up-right-from-square.company-hero-website-icon aria-hidden="true"
            .company-hero-actions
                button.company-suggest-update-btn type="button" data-suggest-update-open=""
                    i.fa-regular.fa-pen-to-square.company-suggest-update-btn-icon aria-hidden="true"
                    | Suggest an update

        section.company-section.company-about-section
            .company-section-label About
            - if @company.description.present?
                p.company-show-body= @company.description
            - else
                p.company-show-body.text-secondary No description has been added for this company yet.
            - secondary_category_name = @company.secondary_category&.name
            - if (@company.category&.name.present? && @company.category.name != "Unknown") || (secondary_category_name.present? && secondary_category_name != "Unknown") || @company.tags.any?
                .company-about-tags
                    - if @company.category&.name.present? && @company.category.name != "Unknown"
                        span.company-about-category
                            span.company-about-category-dot aria-hidden="true"
                            = @company.category.name
                    - if secondary_category_name.present? && secondary_category_name != "Unknown"
                        span.company-about-keyword= secondary_category_name
                    - @company.tags.each do |tag|
                        = link_to tag.name, tag_path(tag.name), class: "company-about-keyword"

        section.company-section
            .company-section-label Key facts
            .company-key-facts-list
                - key_facts.each do |fact|
                    .company-key-fact-card
                        .company-key-fact-icon
                            i class="#{fact[:icon]}" aria-hidden="true"
                        .company-key-fact-copy
                            .company-key-fact-label= fact[:label]
                            .company-key-fact-value= fact[:value]

        - reference_sections.each do |reference_section|
            section.company-section
                .company-section-label= reference_section[:title]
                .company-source-list
                    - reference_section[:links].each do |source_link|
                        - if company_inactive
                            .company-source-row.company-source-row-inactive
                                .company-source-icon
                                    i class="#{source_link[:icon]}" style="color: #{source_link[:icon_color]};"
                                .company-source-label= source_link[:label]
                                .company-source-host= source_link[:host]
                                span.company-source-arrow title=inactive_company_tooltip aria-label=inactive_company_tooltip
                                    span.company-source-inactive-dot aria-hidden="true"
                        - else
                            = link_to source_link[:url], class: "company-source-row", target: "_blank", rel: "noopener" do
                                .company-source-icon
                                    i class="#{source_link[:icon]}" style="color: #{source_link[:icon_color]};"
                                .company-source-label= source_link[:label]
                                .company-source-host= source_link[:host]
                                i.fa-solid.fa-arrow-up-right-from-square.company-source-arrow aria-hidden="true"

        - if academic_ref_entries.any?
            section.company-section
                .company-section-label Academic references
                .company-reference-list
                    - academic_ref_entries.first(5).each_with_index do |reference_entry, index|
                        .company-reference-row
                            .company-source-icon
                                i class="#{reference_entry[:icon]}" style="color: #{reference_entry[:icon_color]};"
                            .company-reference-text
                                span.company-reference-index= "[#{index + 1}]"
                                = reference_entry[:citation]
                            button.company-reference-copy type="button" aria-label="Copy citation #{index + 1}" title="Copy citation" data-citation-copy="true" data-citation=reference_entry[:citation]
                                i.fa-regular.fa-copy aria-hidden="true"

        section.company-section
            .company-citation-header
                .company-section-label.mb-0 Cite this entry
                button.company-reference-copy type="button" aria-label="Copy TechIndex citation" title="Copy citation" data-citation-copy="true" data-citation=citation_text
                    i.fa-regular.fa-copy aria-hidden="true"
            .company-citation-box
                em= citation_text

        - related_company_list @company do |related_companies|
            - if related_companies.any?
                section.company-section
                    .company-section-label Related companies
                    .company-related-grid
                        - related_companies.first(3).each_with_index do |related, index|
                            - related_label = (related.secondary_category&.name.present? && related.secondary_category.name != "Unknown") ? related.secondary_category.name : (related.category&.name.presence || "Legal tech")
                            = link_to company_path(related), class: "company-related-card" do
                                .company-related-avatar style="background: #{related_avatar_colors[index % related_avatar_colors.length]};"
                                    = related.name.to_s.first
                                div
                                    .company-related-name= related.name
                                    .company-related-category= related_label

        .company-maintainer-note
            | Entry maintained by Stanford CodeX. Last reviewed #{reviewed_label}.
            = link_to "Suggest an update", "#", class: "ms-2", data: { suggest_update_open: true }

= render "companies/suggest_update_modal"
= render "shared/citation_copy_script"
