css:
    .public-company-index { background: #f5f3ee; min-height: calc(100vh - 60px); }
    .company-shell { display: grid; grid-template-columns: 15.5rem minmax(0, 1fr); min-height: calc(100vh - 60px); }
    .company-sidebar { background: #eee9df; border-right: 1px solid #ded7ca; padding: 1.25rem 1rem; }
    .company-sidebar-heading { align-items: center; display: flex; justify-content: space-between; margin-bottom: 1.15rem; }
    .company-sidebar-title { color: #3f3933; font-size: 0.76rem; font-weight: 900; letter-spacing: 0.14em; text-transform: uppercase; }
    .company-sidebar-reset { color: #8c1515; font-size: 0.78rem; font-weight: 800; text-decoration: none; }
    .company-sidebar-reset:hover { color: #6f1111; text-decoration: underline; }
    .company-filter-toggle { display: none; }
    .company-filter-toggle-label { display: none; }
    .company-filter-group { margin-top: 1.35rem; }
    .company-filter-heading { color: #7c7369; font-size: 0.7rem; font-weight: 900; letter-spacing: 0.14em; margin-bottom: 0.65rem; text-transform: uppercase; }
    .company-filter-link { align-items: center; border-radius: 0.55rem; color: #4b5563; display: flex; font-size: 0.78rem; font-weight: 500; gap: 0.8rem; justify-content: space-between; line-height: 1.2; padding: 0.46rem 0.65rem; text-decoration: none; }
    .company-filter-link:hover { background: rgba(255, 255, 255, 0.5); color: #111827; }
    .company-filter-link.is-active { background: #f6e5e5; color: #8c1515; font-weight: 800; }
    .company-filter-count { color: #a3a09a; flex: 0 0 auto; font-size: 0.76rem; font-weight: 600; letter-spacing: 0.04em; margin-left: 0.75rem; }
    .company-filter-link.is-active .company-filter-count { color: #a3a09a; }
    .company-main { padding: 0.7rem 1rem 1rem; }
    .company-toolbar { align-items: center; display: grid; gap: 0.65rem; grid-template-columns: minmax(18rem, 1fr) auto; margin-bottom: 0.6rem; }
    .company-toolbar form { margin: 0; }
    .company-search { min-width: 0; }
    .company-search-field { position: relative; }
    .company-search-icon { color: #9ca3af; font-size: 0.82rem; left: 0.95rem; position: absolute; top: 50%; transform: translateY(-50%); }
    .company-search .form-control { background: rgba(255, 255, 255, 0.86); border-color: #ded7ca; border-radius: 0.55rem; font-size: 0.9rem; min-height: 2.85rem; padding-left: 2.3rem; }
    .company-search .form-control:focus { border-color: #cbbfae; box-shadow: 0 0 0 0.15rem rgba(140, 21, 21, 0.08); }
    .company-sort { border-color: #ded7ca; border-radius: 0.55rem; font-size: 0.9rem; min-height: 2.85rem; min-width: 10.25rem; }
    .company-table-card { background: #fff; border: 1px solid #e5dfd5; border-radius: 0.6rem; overflow: hidden; }
    .company-table { font-size: 0.82rem; margin-bottom: 0; min-width: 980px; }
    .company-table thead th { background: #faf8f3; border-bottom: 1px solid #e5dfd5; color: #6b7280; font-size: 0.66rem; font-weight: 800; letter-spacing: 0.05em; padding: 0.58rem 0.75rem; text-transform: uppercase; white-space: nowrap; }
    .company-table tbody td { border-top-color: #f0ebe3; padding: 0.58rem 0.75rem; vertical-align: middle; }
    .company-table tbody tr:hover { background: #fffdf8; }
    .company-name-cell { align-items: center; display: flex; gap: 0.6rem; min-width: 0; }
    .company-logo { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 0.25rem; flex: 0 0 auto; height: 1.75rem; object-fit: contain; padding: 0.12rem; width: 1.75rem; }
    .company-name-link { color: #111827; display: block; font-weight: 700; text-decoration: none; }
    .company-name-link:hover { color: #8c1515; text-decoration: underline; }
    .company-description { color: #6b7280; font-size: 0.72rem; line-height: 1.25; max-width: 36rem; }
    .company-pill { background: #f6f1e7; border: 1px solid #e6ddce; border-radius: 999px; color: #6b6258; display: inline-flex; font-size: 0.68rem; font-weight: 700; padding: 0.12rem 0.45rem; white-space: nowrap; }
    .company-status { background: #e8f5ef; color: #047857; }
    .company-muted { color: #9ca3af; }
    .company-pagination { align-items: center; display: flex; gap: 0.75rem; justify-content: space-between; padding: 0.7rem 0.75rem; }
    .company-pagination-count { color: #8b8379; font-size: 0.76rem; font-weight: 600; }
    .company-pagination .pagination { margin-bottom: 0; }
    @media (max-width: 900px) { .company-shell { grid-template-columns: 1fr; } .company-sidebar { border-right: 0; border-bottom: 1px solid #ded7ca; } .company-toolbar { grid-template-columns: 1fr; } }
    @media (max-width: 640px) { .public-company-index { min-height: auto; } .company-shell { min-height: auto; } .company-sidebar { border-bottom: 1px solid #ded7ca; padding: 0.55rem 0.65rem; } .company-sidebar-heading { display: none; } .company-filter-toggle-label { align-items: center; background: #fff; border: 1px solid #ded7ca; border-radius: 0.6rem; color: #3f3933; display: flex; font-size: 0.86rem; font-weight: 800; justify-content: space-between; min-height: 2.45rem; padding: 0 0.8rem; } .company-filter-toggle-label::after { color: #8c1515; content: "Show"; font-size: 0.74rem; font-weight: 900; letter-spacing: 0.06em; text-transform: uppercase; } .company-filter-toggle:checked + .company-filter-toggle-label::after { content: "Hide"; } .company-filter-content { display: none; max-height: 18rem; overflow-y: auto; padding-top: 0.65rem; } .company-filter-toggle:checked ~ .company-filter-content { display: block; } .company-filter-group { margin-top: 0.9rem; } .company-filter-link { padding: 0.42rem 0.55rem; } .company-main { padding: 0.45rem 0.65rem 0.9rem; } .company-toolbar { gap: 0.45rem; margin-bottom: 0.55rem; } .company-search .form-control, .company-sort { font-size: 0.86rem; min-height: 2.45rem; width: 100%; } .company-search .form-control { padding-left: 2.15rem; } .company-search-icon { left: 0.85rem; } .company-table-card { background: transparent; border: 0; border-radius: 0; overflow: visible; } .company-table { border-collapse: collapse; border-spacing: 0; min-width: 0; } .company-table thead { display: none; } .company-table tbody, .company-table tr, .company-table td { display: block; width: 100%; } .company-table tbody tr { background: #fff; border: 1px solid #e5dfd5; border-radius: 0.75rem; box-shadow: 0 1px 4px rgba(17, 24, 39, 0.04); margin-bottom: 0.85rem; overflow: hidden; } .company-table tbody td { align-items: center; border-top: 1px solid #f3eee6; display: flex; gap: 0.75rem; justify-content: space-between; padding: 0.58rem 0.75rem; } .company-table tbody td:first-child { border-top: 0; display: block; padding: 0.72rem 0.75rem; } .company-table tbody td:not(:first-child)::before { color: #8b8379; content: attr(data-label); flex: 0 0 auto; font-size: 0.62rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; } .company-name-cell { align-items: flex-start; } .company-logo { height: 2rem; width: 2rem; } .company-description { max-width: none; } .company-pagination { align-items: flex-start; flex-direction: column; gap: 0.55rem; padding: 0.3rem 0.1rem 0; } .company-pagination .pagination { flex-wrap: wrap; } }

- active_params = request.query_parameters.symbolize_keys
- clear_params = active_params.except(:category, :status, :location, :query, :page)
- selected_category = params[:category].presence
- selected_status = params[:status].to_s.strip.downcase.presence
- result_start = @companies.empty? ? 0 : @companies.offset_value + 1
- result_end = @companies.offset_value + @companies.length

.public-company-index
    .company-shell
        aside.company-sidebar
            .company-sidebar-heading
                .company-sidebar-title Filter
                - if active_params.slice(:category, :status, :location, :query).any?
                    = link_to "Reset", companies_path(clear_params), class: "company-sidebar-reset"
            input#company-filter-toggle.company-filter-toggle type="checkbox"
            label.company-filter-toggle-label for="company-filter-toggle"
                span Filter companies
            .company-filter-content
                .company-filter-group.mt-0
                    .company-filter-heading Category
                    = link_to companies_path(active_params.except(:category, :page)), class: "company-filter-link #{selected_category.blank? ? 'is-active' : ''}" do
                        span All categories
                        span.company-filter-count= number_with_delimiter(@base_companies.count)
                    - @category_counts.each do |category|
                        = link_to companies_path(active_params.merge(category: category[:id]).except(:page)), class: "company-filter-link #{selected_category.to_s == category[:id].to_s ? 'is-active' : ''}" do
                            span= category[:name]
                            span.company-filter-count= number_with_delimiter(category[:count])
                - if @status_counts.any?
                    .company-filter-group
                        .company-filter-heading Status
                        = link_to companies_path(active_params.except(:status, :page)), class: "company-filter-link #{selected_status.blank? ? 'is-active' : ''}" do
                            span Any status
                            span.company-filter-count= number_with_delimiter(@base_companies.count)
                        - @status_counts.each do |status, count|
                            = link_to companies_path(active_params.merge(status: status).except(:page)), class: "company-filter-link #{selected_status == status ? 'is-active' : ''}" do
                                span= status.to_s.humanize
                                span.company-filter-count= number_with_delimiter(count)
                .company-filter-group
                    .company-filter-heading Location
                    = form_with url: companies_path, method: :get, local: true do
                        = hidden_field_tag :query, params[:query] if params[:query].present?
                        = hidden_field_tag :category, params[:category] if params[:category].present?
                        = hidden_field_tag :status, params[:status] if params[:status].present?
                        = hidden_field_tag :sort, params[:sort] if params[:sort].present?
                        = text_field_tag :location, params[:location], class: "form-control form-control-sm mt-2", placeholder: "City, region, country"
                        button.btn.btn-sm.btn-outline-secondary.w-100.mt-2 type="submit" Apply

        main.company-main
            .company-toolbar
                = form_with url: companies_path, method: :get, local: true, html: { class: "company-search" } do
                    = hidden_field_tag :category, params[:category] if params[:category].present?
                    = hidden_field_tag :status, params[:status] if params[:status].present?
                    = hidden_field_tag :location, params[:location] if params[:location].present?
                    = hidden_field_tag :sort, params[:sort] if params[:sort].present?
                    .company-search-field
                        i.fa.fa-search.company-search-icon aria-hidden="true"
                        = search_field_tag :query, params[:query], class: "form-control", placeholder: "Search companies by name, category, or location", aria: { label: "Search companies" }
                = form_with url: companies_path, method: :get, local: true do
                    = hidden_field_tag :query, params[:query] if params[:query].present?
                    = hidden_field_tag :category, params[:category] if params[:category].present?
                    = hidden_field_tag :status, params[:status] if params[:status].present?
                    = hidden_field_tag :location, params[:location] if params[:location].present?
                    = select_tag :sort, options_for_select(@sort_options, params[:sort].presence || "founded_desc"), class: "form-select form-select-sm company-sort", onchange: "this.form.submit()", aria: { label: "Sort companies" }

            .company-table-card
                .table-responsive
                    table.table.company-table.align-middle
                        thead
                            tr
                                th Company
                                th Category
                                th Founded
                                th HQ
                                th Funding
                                th Status
                        tbody
                            - @companies.each do |company|
                                tr
                                    td
                                        .company-name-cell
                                            = image_tag company.logo, class: "company-logo", alt: "#{company.name} logo", loading: "lazy"
                                            div
                                                = link_to company.name, company_path(company), class: "company-name-link"
                                                .company-description= truncate(company.description.to_s, length: 105)
                                    td data-label="Category"
                                        span.company-pill= company.category&.name || "Uncategorized"
                                    td data-label="Founded"= company.founded_date.presence || "N/A"
                                    td data-label="HQ"= company.location.presence || "N/A"
                                    td data-label="Funding"
                                        - if company.total_funding_amount_usd.present? && company.total_funding_amount_usd.positive?
                                            = number_to_currency(company.total_funding_amount_usd, precision: 0)
                                        - else
                                            span.company-muted Not disclosed
                                    td data-label="Status"
                                        span.company-pill.company-status= company.status.presence&.humanize || "Active"
                            - if @companies.empty?
                                tr
                                    td.text-center.company-muted py="4" colspan="6" No companies match these filters.
                .company-pagination
                    .company-pagination-count= "Showing #{result_start}-#{result_end} of #{number_with_delimiter(@total_count)} companies"
                    = paginate @companies
