- search_categories = company_search_categories

css:
    .company-search-modal { align-items: flex-start; display: none; inset: 0; justify-content: center; padding: 4.5rem 1rem 1.5rem; position: fixed; z-index: 2000; }
    .company-search-modal.is-open { display: flex; }
    .company-search-modal-backdrop { background: rgba(15, 23, 42, 0.72); inset: 0; position: absolute; }
    .company-search-modal-panel { background: #fff; border-radius: 0.85rem; box-shadow: 0 24px 64px rgba(15, 23, 42, 0.28); max-width: 38rem; overflow: hidden; position: relative; width: 100%; }
    .company-search-modal-input { align-items: center; display: flex; gap: 0.75rem; padding: 0.95rem 1rem; }
    .company-search-modal-input-icon { color: #9ca3af; flex: 0 0 auto; font-size: 0.95rem; }
    .company-search-modal-input-field { background: transparent; border: 0; color: #111827; flex: 1 1 auto; font-size: 0.98rem; min-width: 0; outline: none; padding: 0; }
    .company-search-modal-input-field::placeholder { color: #9ca3af; }
    .company-search-modal-divider { background: #e5e7eb; height: 1px; }
    .company-search-modal-body { max-height: min(28rem, calc(100vh - 10rem)); overflow-y: auto; padding-bottom: 0.35rem; }
    .company-search-modal-section-label { color: #9ca3af; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; padding: 0.85rem 1rem 0.5rem; text-transform: uppercase; }
    .company-search-modal-item { align-items: center; color: inherit; display: flex; gap: 0.85rem; min-height: 3.25rem; padding: 0.65rem 1rem; text-decoration: none; transition: background 0.12s ease; }
    .company-search-modal-item:hover, .company-search-modal-item.is-active { background: #f8fafc; color: inherit; text-decoration: none; }
    .company-search-modal-item + .company-search-modal-item { border-top: 1px solid #f3f4f6; }
    .company-search-modal-item-icon { align-items: center; background: #f3efe6; border-radius: 0.45rem; color: #6b6258; display: flex; flex: 0 0 auto; font-size: 0.82rem; height: 2.15rem; justify-content: center; width: 2.15rem; }
    .company-search-modal-item-logo { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 0.35rem; flex: 0 0 auto; height: 2.15rem; object-fit: contain; padding: 0.12rem; width: 2.15rem; }
    .company-search-modal-item-copy { display: flex; flex: 1 1 auto; flex-direction: column; gap: 0.15rem; justify-content: center; min-width: 0; }
    .company-search-modal-item-title { color: #111827; display: block; font-size: 0.92rem; font-weight: 600; line-height: 1.3; }
    .company-search-modal-item-subtitle { color: #9ca3af; display: block; font-size: 0.78rem; line-height: 1.25; }
    .company-search-modal-results .company-search-modal-item-title, .company-search-modal-results .company-search-modal-item-subtitle { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .company-search-modal-item-chevron { color: #cbd5e1; flex: 0 0 auto; font-size: 0.72rem; margin-left: 0.25rem; }
    .company-search-modal-empty { color: #9ca3af; font-size: 0.92rem; padding: 2.5rem 1rem; text-align: center; }
    .company-search-modal-footer { border-top: 1px solid #f3f4f6; padding: 0.55rem 1rem 0.75rem; }
    .company-search-modal-footer-link { color: #8c1515; display: inline-block; font-size: 0.84rem; font-weight: 700; text-decoration: none; }
    .company-search-modal-footer-link:hover { color: #6f1111; text-decoration: underline; }
    @media (max-width: 640px) { .company-search-modal { padding-top: 1rem; } .company-search-modal-panel { border-radius: 0.75rem; } }

#company-search-modal.company-search-modal aria-hidden="true" data-search-url=search_companies_path(format: :json) data-companies-url=companies_path
    .company-search-modal-backdrop data-company-search-close=""
    .company-search-modal-panel role="dialog" aria-modal="true" aria-labelledby="company-search-modal-label"
        .company-search-modal-input
            i.fa.fa-search.company-search-modal-input-icon aria-hidden="true"
            input#company-search-modal-input.company-search-modal-input-field type="search" placeholder="Search companies..." autocomplete="off" aria-labelledby="company-search-modal-label"
            span.visually-hidden#company-search-modal-label Search companies
        .company-search-modal-divider
        .company-search-modal-body data-company-search-body=""
            .company-search-modal-section data-company-search-categories=""
                .company-search-modal-section-label Categories
                - search_categories.each do |category|
                    a.company-search-modal-item href=category[:url]
                        span.company-search-modal-item-icon
                            i class=category[:icon] aria-hidden="true"
                        span.company-search-modal-item-copy
                            span.company-search-modal-item-title= category[:name]
                            span.company-search-modal-item-subtitle= "#{number_with_delimiter(category[:count])} companies"
                        i.fa.fa-chevron-right.company-search-modal-item-chevron aria-hidden="true"
            .company-search-modal-section.d-none data-company-search-results=""
                .company-search-modal-section-label Companies
                .company-search-modal-results data-company-search-results-list=""
                .company-search-modal-footer.d-none data-company-search-footer=""
                    a.company-search-modal-footer-link data-company-search-view-all="" href=companies_path View all results

javascript:
    (function() {
        let searchTimer = null;
        let activeController = null;

        function initNavSearchShortcut() {
            const field = document.querySelector(".public-nav-search-field");
            const shortcut = document.querySelector("[data-nav-search-shortcut]");
            const trigger = document.querySelector("[data-nav-search-trigger]");
            if (!field || !shortcut || field.dataset.shortcutInitialized === "true") return;
            field.dataset.shortcutInitialized = "true";

            const supportsShortcut = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
            if (!supportsShortcut) return;

            const isMac = /Mac|iPhone|iPad|iPod/.test(navigator.platform) || /Mac OS X/.test(navigator.userAgent);
            const shortcutLabel = isMac ? "⌘K" : "Ctrl K";
            shortcut.textContent = shortcutLabel;
            field.classList.add("has-shortcut");

            if (trigger) {
                trigger.setAttribute("aria-label", "Search companies (" + shortcutLabel + ")");
            }
        }

        function initCompanySearchModal() {
            const modal = document.getElementById("company-search-modal");
            const modalInput = document.getElementById("company-search-modal-input");
            if (!modal || !modalInput || modal.dataset.initialized === "true") return;
            modal.dataset.initialized = "true";

            const categoriesSection = modal.querySelector("[data-company-search-categories]");
            const resultsSection = modal.querySelector("[data-company-search-results]");
            const resultsList = modal.querySelector("[data-company-search-results-list]");
            const footer = modal.querySelector("[data-company-search-footer]");
            const viewAllLink = modal.querySelector("[data-company-search-view-all]");
            const searchUrl = modal.dataset.searchUrl;
            const companiesUrl = modal.dataset.companiesUrl;
            const triggers = document.querySelectorAll("[data-nav-search-trigger]");

            function openModal(initialQuery) {
                modal.classList.add("is-open");
                modal.setAttribute("aria-hidden", "false");
                document.body.style.overflow = "hidden";
                modalInput.value = initialQuery || "";
                resetResults();
                if (modalInput.value.trim()) {
                    runSearch(modalInput.value.trim());
                }
                window.setTimeout(function() { modalInput.focus(); }, 0);
            }

            function closeModal() {
                modal.classList.remove("is-open");
                modal.setAttribute("aria-hidden", "true");
                document.body.style.overflow = "";
            }

            function resetResults() {
                resultsList.innerHTML = "";
                resultsSection.classList.add("d-none");
                footer.classList.add("d-none");
                categoriesSection.classList.remove("d-none");
            }

            function showEmptyState(message) {
                resultsSection.classList.remove("d-none");
                categoriesSection.classList.add("d-none");
                footer.classList.add("d-none");
                resultsList.innerHTML = '<div class="company-search-modal-empty">' + message + "</div>";
            }

            function renderCompanies(companies, totalCount, query) {
                resultsSection.classList.remove("d-none");
                categoriesSection.classList.add("d-none");
                resultsList.innerHTML = "";

                if (!companies.length) {
                    showEmptyState("No companies found");
                    return;
                }

                companies.forEach(function(company) {
                    const link = document.createElement("a");
                    link.className = "company-search-modal-item";
                    link.href = company.url;

                    const logo = document.createElement("img");
                    logo.className = "company-search-modal-item-logo";
                    logo.alt = "";
                    logo.src = company.logo;
                    logo.onerror = function() {
                        logo.src = "https://placehold.co/64x64?text=" + encodeURIComponent((company.name || "?").charAt(0));
                    };

                    const copy = document.createElement("span");
                    copy.className = "company-search-modal-item-copy";

                    const title = document.createElement("span");
                    title.className = "company-search-modal-item-title";
                    title.textContent = company.name;

                    copy.appendChild(title);

                    if (company.subtitle) {
                        const subtitle = document.createElement("span");
                        subtitle.className = "company-search-modal-item-subtitle";
                        subtitle.textContent = company.subtitle;
                        copy.appendChild(subtitle);
                    }

                    const chevron = document.createElement("i");
                    chevron.className = "fa fa-chevron-right company-search-modal-item-chevron";
                    chevron.setAttribute("aria-hidden", "true");

                    link.appendChild(logo);
                    link.appendChild(copy);
                    link.appendChild(chevron);
                    resultsList.appendChild(link);
                });

                if (totalCount > companies.length) {
                    viewAllLink.href = companiesUrl + "?query=" + encodeURIComponent(query);
                    viewAllLink.textContent = "View all " + totalCount.toLocaleString() + " results";
                    footer.classList.remove("d-none");
                } else {
                    footer.classList.add("d-none");
                }
            }

            function runSearch(query) {
                if (activeController) activeController.abort();
                if (!query) {
                    resetResults();
                    return;
                }

                activeController = new AbortController();
                fetch(searchUrl + "?q=" + encodeURIComponent(query), { headers: { Accept: "application/json" }, signal: activeController.signal })
                    .then(function(response) { return response.json(); })
                    .then(function(payload) {
                        renderCompanies(payload.companies || [], payload.total_count || 0, query);
                    })
                    .catch(function(error) {
                        if (error.name !== "AbortError") showEmptyState("Search is temporarily unavailable");
                    });
            }

            triggers.forEach(function(trigger) {
                trigger.addEventListener("click", function(event) {
                    event.preventDefault();
                    openModal(trigger.value || "");
                });
                trigger.addEventListener("keydown", function(event) {
                    if (event.key === "Enter" || event.key === " ") {
                        event.preventDefault();
                        openModal(trigger.value || "");
                    }
                });
            });

            modal.querySelectorAll("[data-company-search-close]").forEach(function(element) {
                element.addEventListener("click", closeModal);
            });

            modalInput.addEventListener("input", function() {
                window.clearTimeout(searchTimer);
                const query = modalInput.value.trim();
                searchTimer = window.setTimeout(function() { runSearch(query); }, 250);
            });

            modalInput.addEventListener("keydown", function(event) {
                if (event.key === "Escape") {
                    event.preventDefault();
                    closeModal();
                }
                if (event.key === "Enter" && modalInput.value.trim()) {
                    event.preventDefault();
                    window.location.href = companiesUrl + "?query=" + encodeURIComponent(modalInput.value.trim());
                }
            });

            document.addEventListener("keydown", function(event) {
                if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k") {
                    event.preventDefault();
                    openModal("");
                }
                if (event.key === "Escape" && modal.classList.contains("is-open")) closeModal();
            });
        }

        document.addEventListener("DOMContentLoaded", function() {
            initNavSearchShortcut();
            initCompanySearchModal();
        });
        document.addEventListener("turbo:load", function() {
            initNavSearchShortcut();
            initCompanySearchModal();
        });
    })();
