/ locals: path, title, description, meta (optional), visual_html (optional), sparkline_variant (optional, 1-4, 6-7)
- sparkline_variant ||= (title.hash.abs % 4) + 1
= link_to path, class: "stats-index-card" do
    h3.stats-index-card-title= title
    p.stats-index-card-desc= description
    .stats-index-card-visual aria-hidden="true"
        - if local_assigns[:visual_html].present?
            == visual_html
        - elsif sparkline_variant == 1
            svg viewBox="0 0 240 48" preserveAspectRatio="none" width="100%" height="100%"
                rect x="6" y="36" width="20" height="12" fill="#8c1515" rx="2"
                rect x="34" y="32" width="20" height="16" fill="#8c1515" rx="2"
                rect x="62" y="28" width="20" height="20" fill="#8c1515" rx="2"
                rect x="90" y="24" width="20" height="24" fill="#8c1515" rx="2"
                rect x="118" y="20" width="20" height="28" fill="#8c1515" rx="2"
                rect x="146" y="16" width="20" height="32" fill="#8c1515" rx="2"
                rect x="174" y="12" width="20" height="36" fill="#8c1515" rx="2"
                rect x="202" y="8" width="20" height="40" fill="#8c1515" rx="2"
        - elsif sparkline_variant == 2
            svg viewBox="0 0 240 48" preserveAspectRatio="none" width="100%" height="100%"
                path fill="none" stroke="#175e54" stroke-width="2" stroke-linecap="round" d="M0,12 L40,16 L80,24 L120,20 L160,30 L200,26 L240,36"
                path fill="url(#sparkGrad2)" d="M0,12 L40,16 L80,24 L120,20 L160,30 L200,26 L240,36 L240,48 L0,48 Z"
                defs
                    linearGradient#sparkGrad2 x1="0" y1="0" x2="0" y2="1"
                        stop offset="0%" stop-color="#175e54" stop-opacity="0.16"
                        stop offset="100%" stop-color="#175e54" stop-opacity="0"
        - elsif sparkline_variant == 3
            svg viewBox="0 0 240 48" preserveAspectRatio="none" width="100%" height="100%"
                rect x="8" y="28" width="18" height="20" fill="#8c1515" rx="2"
                rect x="38" y="20" width="18" height="28" fill="#8c1515" rx="2"
                rect x="68" y="24" width="18" height="24" fill="#8c1515" rx="2"
                rect x="98" y="14" width="18" height="34" fill="#8c1515" rx="2"
                rect x="128" y="18" width="18" height="30" fill="#8c1515" rx="2"
                rect x="158" y="10" width="18" height="38" fill="#8c1515" rx="2"
                rect x="188" y="16" width="18" height="32" fill="#8c1515" rx="2"
                rect x="218" y="8" width="18" height="40" fill="#8c1515" rx="2"
        - elsif sparkline_variant == 4
            svg viewBox="0 0 240 48" preserveAspectRatio="none" width="100%" height="100%"
                path fill="none" stroke="#8c1515" stroke-width="2" stroke-linecap="round" d="M0,24 L60,24 L60,8 L120,8 L120,32 L180,32 L180,16 L240,16"
        - elsif sparkline_variant == 7
            svg viewBox="0 0 240 48" preserveAspectRatio="none" width="100%" height="100%"
                rect x="8" y="28" width="18" height="20" fill="#175e54" rx="2"
                rect x="38" y="20" width="18" height="28" fill="#175e54" rx="2"
                rect x="68" y="24" width="18" height="24" fill="#175e54" rx="2"
                rect x="98" y="14" width="18" height="34" fill="#175e54" rx="2"
                rect x="128" y="18" width="18" height="30" fill="#175e54" rx="2"
                rect x="158" y="10" width="18" height="38" fill="#175e54" rx="2"
                rect x="188" y="16" width="18" height="32" fill="#175e54" rx="2"
                rect x="218" y="8" width="18" height="40" fill="#175e54" rx="2"
        - else
            svg viewBox="0 0 240 48" preserveAspectRatio="none" width="100%" height="100%"
                path fill="none" stroke="#175e54" stroke-width="2" stroke-linecap="round" d="M0,38 L30,34 L60,30 L90,26 L120,20 L150,16 L180,10 L210,8 L240,4"
                path fill="url(#sparkGradCategory)" d="M0,38 L30,34 L60,30 L90,26 L120,20 L150,16 L180,10 L210,8 L240,4 L240,48 L0,48 Z"
                defs
                    linearGradient#sparkGradCategory x1="0" y1="0" x2="0" y2="1"
                        stop offset="0%" stop-color="#175e54" stop-opacity="0.18"
                        stop offset="100%" stop-color="#175e54" stop-opacity="0"
    .stats-index-card-footer
        - if local_assigns[:meta].present?
            span.stats-index-card-meta= meta
        span.stats-index-card-action
            | View
            i.fas.fa-arrow-right aria-hidden="true"
