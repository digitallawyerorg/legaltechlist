css:
    .stats-page {
        background: #f3efe6;
        flex: 1 0 auto;
        width: 100%;
    }

    .stats-page-inner {
        margin: 0 auto;
        max-width: 100%;
        padding: clamp(1.25rem, 3vw, 2.5rem) clamp(1rem, 4vw, 3rem) 3rem;
        width: 100%;
    }

    .stats-page-inner-chart {
        padding-top: clamp(0.5rem, 1.25vw, 0.85rem);
    }

    @media (min-width: 1200px) {
        .stats-page-inner-chart {
            padding-left: clamp(0.75rem, 1.5vw, 1.25rem);
            padding-right: clamp(0.75rem, 1.5vw, 1.25rem);
        }

        .stats-page-inner.stats-page-inner-chart:has(.stats-country-geo-map) {
            padding-left: clamp(0.35rem, 0.85vw, 0.75rem);
            padding-right: clamp(0.35rem, 0.85vw, 0.75rem);
        }

        .stats-chart-card:has(.stats-country-geo-map) .stats-chart-header {
            padding-left: 1rem;
            padding-right: 1rem;
        }
    }

    .stats-country-geo-map {
        margin: 0 auto;
        min-height: 480px;
        width: 100%;
    }

    .stats-country-geo-map > div {
        margin: 0 auto;
        width: 100% !important;
    }

    .stats-chart-nav {
        align-items: center;
        display: flex;
        gap: 1rem;
        justify-content: space-between;
        margin-bottom: 0.85rem;
    }

    .stats-chart-nav-link {
        align-items: center;
        color: rgba(42, 39, 35, 0.68);
        display: inline-flex;
        font-size: 0.875rem;
        font-weight: 500;
        gap: 0.45rem;
        line-height: 1.25;
        max-width: min(48%, 26rem);
        min-width: 0;
        text-decoration: none;
    }

    .stats-chart-nav-link:hover {
        color: #8c1515;
        text-decoration: none;
    }

    .stats-chart-nav-prev {
        justify-content: flex-start;
    }

    .stats-chart-nav-next {
        justify-content: flex-end;
        margin-left: auto;
    }

    .stats-chart-nav-icon {
        color: rgba(42, 39, 35, 0.42);
        flex-shrink: 0;
        font-size: 0.72rem;
    }

    .stats-chart-nav-link:hover .stats-chart-nav-icon {
        color: #8c1515;
    }

    .stats-chart-nav-title {
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .stats-region-row td {
        background: rgba(140, 21, 21, 0.04);
    }

    .stats-country-cell {
        align-items: center;
        display: inline-flex;
        gap: 0.4rem;
    }

    .stats-country-flag {
        flex: 0 0 auto;
        font-size: 1rem;
        line-height: 1;
    }

    .stats-region-sunburst,
    .stats-region-sankey {
        min-height: 480px;
        width: 100%;
    }

    .stats-sunburst-wrap,
    .stats-sankey-wrap {
        width: 100%;
    }

    .stats-chart-header-row {
        align-items: flex-start;
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: space-between;
        width: 100%;
    }

    .stats-chart-heading {
        min-width: 0;
    }

    .stats-hero {
        margin-bottom: 2rem;
    }

    .stats-hero-title {
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(1.75rem, 3vw, 2.35rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin: 0 0 0.5rem;
    }

    .stats-hero-subtitle {
        color: rgba(42, 39, 35, 0.62);
        font-size: 1rem;
        line-height: 1.55;
        margin: 0;
        max-width: 42rem;
    }

    .stats-index-grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    @media (max-width: 992px) {
        .stats-index-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 640px) {
        .stats-index-grid {
            grid-template-columns: 1fr;
        }
    }

    .stats-index-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05), 0 6px 20px rgba(42, 39, 35, 0.04);
        color: inherit;
        display: flex;
        flex-direction: column;
        min-height: 100%;
        padding: 1.4rem 1.4rem 1.2rem;
        text-decoration: none;
        transition: box-shadow 0.18s ease, transform 0.18s ease;
    }

    .stats-index-card:hover {
        box-shadow: 0 2px 6px rgba(42, 39, 35, 0.07), 0 10px 28px rgba(42, 39, 35, 0.08);
        color: inherit;
        text-decoration: none;
        transform: translateY(-2px);
    }

    .stats-index-card-title {
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.22rem;
        font-weight: 500;
        line-height: 1.25;
        margin: 0 0 0.55rem;
    }

    .stats-index-card-desc {
        color: rgba(42, 39, 35, 0.62);
        font-size: 0.88rem;
        line-height: 1.55;
        margin: 0 0 1.1rem;
    }

    .stats-index-card-visual {
        align-items: stretch;
        display: flex;
        flex-direction: column;
        justify-content: center;
        margin-bottom: 1rem;
        min-height: 88px;
        overflow: hidden;
        padding: 0;
        width: 100%;
    }

    .stats-index-card-visual:has(.stats-index-card-country-bars) {
        justify-content: flex-start;
        min-height: 88px;
    }

    .stats-index-card-country-bars {
        display: flex;
        flex-direction: column;
        gap: 0.42rem;
        padding-bottom: 0.15rem;
        padding-top: 0.95rem;
        width: 100%;
    }

    .stats-index-card-country-row {
        align-items: center;
        display: grid;
        gap: 0.55rem;
        grid-template-columns: 6.75rem minmax(0, 1fr) 2rem;
    }

    .stats-index-card-country-label {
        color: rgba(42, 39, 35, 0.62);
        font-size: 0.7rem;
        line-height: 1.25;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .stats-index-card-country-track {
        background: #eeeae3;
        border-radius: 999px;
        height: 7px;
        overflow: hidden;
        width: 100%;
    }

    .stats-index-card-country-fill {
        background: #175e54;
        border-radius: 999px;
        height: 100%;
        min-width: 3px;
    }

    .stats-index-card-country-share {
        color: rgba(42, 39, 35, 0.52);
        font-size: 0.7rem;
        line-height: 1.25;
        text-align: right;
        white-space: nowrap;
    }

    .stats-index-card-vertical-bars {
        align-items: flex-end;
        display: flex;
        gap: 0.45rem;
        height: 100%;
        justify-content: space-between;
        min-height: 88px;
        padding-top: 0.35rem;
        width: 100%;
    }

    .stats-index-card-vertical-bar {
        align-items: flex-end;
        display: flex;
        flex: 1 1 0;
        height: 100%;
        min-width: 0;
    }

    .stats-index-card-vertical-bar-fill {
        border-radius: 2px 2px 0 0;
        min-height: 3px;
        width: 100%;
    }

    .stats-index-card-area-line {
        display: block;
        min-height: 88px;
        width: 100%;
    }

    .stats-index-card-footer {
        align-items: center;
        border-top: 1px solid rgba(42, 39, 35, 0.08);
        display: flex;
        gap: 0.75rem;
        justify-content: space-between;
        margin-top: auto;
        padding-top: 0.85rem;
    }

    .stats-index-card-meta {
        color: rgba(42, 39, 35, 0.48);
        font-size: 0.78rem;
        font-weight: 500;
        line-height: 1.3;
    }

    .stats-index-card-action {
        align-items: center;
        color: #8c1515;
        display: inline-flex;
        flex-shrink: 0;
        font-size: 0.82rem;
        font-weight: 600;
        gap: 0.35rem;
        margin-left: auto;
    }

    .stats-chart-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05), 0 6px 20px rgba(42, 39, 35, 0.04);
        margin-bottom: 1.25rem;
        overflow: hidden;
    }

    .stats-chart-header {
        border-bottom: 1px solid rgba(42, 39, 35, 0.06);
        display: flex;
        flex-direction: column;
        padding: 1.35rem 1.5rem 1.15rem;
    }

    .stats-chart-title {
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(1.35rem, 2.2vw, 1.65rem);
        font-weight: 500;
        letter-spacing: -0.01em;
        line-height: 1.2;
        margin: 0 0 0.35rem;
    }

    .stats-chart-subtitle {
        color: rgba(42, 39, 35, 0.58);
        font-size: 0.92rem;
        line-height: 1.45;
        margin: 0;
        max-width: 40rem;
    }

    .stats-chart-controls {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .stats-pill-group {
        align-items: center;
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .stats-dimension-select {
        background-color: #fff;
        border: 1px solid rgba(42, 39, 35, 0.14);
        border-radius: 999px;
        color: #2a2723;
        font-size: 0.82rem;
        font-weight: 600;
        min-width: 11rem;
        padding: 0.42rem 2rem 0.42rem 0.85rem;
    }

    .stats-segment-control {
        background: #eeeae3;
        border-radius: 999px;
        display: inline-flex;
        padding: 0.18rem;
    }

    .stats-segment {
        border: 0;
        border-radius: 999px;
        color: rgba(42, 39, 35, 0.62);
        font-size: 0.78rem;
        font-weight: 600;
        line-height: 1.2;
        padding: 0.38rem 0.9rem;
        text-decoration: none;
        transition: background 0.15s ease, box-shadow 0.15s ease, color 0.15s ease;
        white-space: nowrap;
    }

    .stats-segment:hover {
        color: #8c1515;
        text-decoration: none;
    }

    .stats-segment.is-active {
        background: #8c1515;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.08);
        color: #fff;
    }

    .stats-segment.is-active:hover {
        color: #fff;
    }

    .stats-pill {
        background: #eeeae3;
        border-radius: 999px;
        color: rgba(42, 39, 35, 0.68);
        font-size: 0.78rem;
        font-weight: 600;
        padding: 0.38rem 0.85rem;
        text-decoration: none;
        transition: background 0.15s ease, color 0.15s ease;
    }

    .stats-pill:hover {
        background: rgba(140, 21, 21, 0.12);
        color: #8c1515;
        text-decoration: none;
    }

    .stats-pill.is-active {
        background: #8c1515;
        color: #fff;
    }

    .stats-export-btn {
        align-items: center;
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.12);
        border-radius: 10px;
        color: rgba(42, 39, 35, 0.72);
        display: inline-flex;
        font-size: 0.82rem;
        font-weight: 600;
        gap: 0.4rem;
        padding: 0.45rem 0.85rem;
    }

    .stats-export-btn:hover {
        background: #faf8f4;
        border-color: rgba(42, 39, 35, 0.18);
        color: #2a2723;
    }

    .stats-export-btn.dropdown-toggle::after {
        margin-left: 0.35rem;
        vertical-align: 0.12em;
    }

    .stats-chart-controls .dropdown-menu .dropdown-item.active {
        background: rgba(140, 21, 21, 0.08);
        color: #8c1515;
        font-weight: 600;
    }

    .stats-category-filter-menu {
        min-width: 16rem;
        padding: 0.65rem;
        width: min(22rem, 92vw);
    }

    .stats-category-filter-list {
        max-height: 16rem;
        overflow-y: auto;
        padding-right: 0.15rem;
    }

    .stats-category-filter-item + .stats-category-filter-item {
        margin-top: 0.15rem;
    }

    .stats-category-filter-label {
        align-items: center;
        border-radius: 8px;
        color: #2a2723;
        cursor: pointer;
        display: flex;
        font-size: 0.86rem;
        gap: 0.55rem;
        line-height: 1.35;
        margin: 0;
        padding: 0.35rem 0.45rem;
    }

    .stats-category-filter-label:hover {
        background: rgba(42, 39, 35, 0.04);
    }

    .stats-category-filter-checkbox {
        flex-shrink: 0;
        margin: 0;
    }

    .stats-category-filter-actions {
        border-top: 1px solid rgba(42, 39, 35, 0.08);
        display: flex;
        justify-content: flex-end;
        margin-top: 0.65rem;
        padding-top: 0.65rem;
    }

    .stats-category-filter-reset {
        background: none;
        border: none;
        color: rgba(42, 39, 35, 0.62);
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0;
        text-decoration: none;
    }

    .stats-category-filter-reset:hover {
        color: #8c1515;
    }

    .stats-chart-body {
        padding: 0.75rem 1rem 1.25rem;
    }

    .stats-chart-body:has(.stats-country-geo-map) {
        padding: 0.35rem 0.4rem 0.85rem;
    }

    .stats-chart-body > div[id]:not(.stats-country-geo-map),
    .stats-chart-body .stats-region-sunburst[id],
    .stats-chart-body .stats-region-sankey[id],
    .stats-period-card-body > div[id] {
        width: 100%;
    }

    .stats-chart-body .stats-country-geo-map[id] {
        width: 100%;
    }

    @media (min-width: 992px) {
        .stats-chart-body > div[id]:not(.stats-country-geo-map),
        .stats-chart-body .stats-region-sunburst[id],
        .stats-chart-body .stats-region-sankey[id],
        .stats-period-card-body > div[id] {
            height: clamp(30rem, calc(100vh - 17rem), 52rem) !important;
            min-height: clamp(30rem, calc(100vh - 17rem), 52rem);
        }
    }

    @media (min-width: 1400px) {
        .stats-chart-body > div[id]:not(.stats-country-geo-map),
        .stats-chart-body .stats-region-sunburst[id],
        .stats-chart-body .stats-region-sankey[id],
        .stats-period-card-body > div[id] {
            height: clamp(34rem, calc(100vh - 15rem), 56rem) !important;
            min-height: clamp(34rem, calc(100vh - 15rem), 56rem);
        }
    }

    .stats-table-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05), 0 6px 20px rgba(42, 39, 35, 0.04);
        margin-bottom: 1.25rem;
        overflow: hidden;
    }

    .stats-table-card-header {
        border-bottom: 1px solid rgba(42, 39, 35, 0.06);
        padding: 1.1rem 1.5rem;
    }

    .stats-table-title {
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.05rem;
        font-weight: 500;
        margin: 0;
    }

    .stats-table-card-body {
        padding: 0.25rem 0.5rem 0.75rem;
    }

    .stats-table-card-body .table {
        margin-bottom: 0;
    }

    .stats-table-card-body .table thead th {
        background: transparent;
        border-bottom: 1px solid rgba(42, 39, 35, 0.08);
        color: rgba(42, 39, 35, 0.48);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        padding: 0.85rem 1rem;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .stats-table-card-body .table tbody td {
        border-bottom: 1px solid rgba(42, 39, 35, 0.05);
        color: #2a2723;
        font-size: 0.9rem;
        padding: 0.95rem 1rem;
        vertical-align: middle;
    }

    .stats-table-card-body .table tbody tr:last-child td {
        border-bottom: 0;
    }

    .stats-table-card-body .table-hover tbody tr:hover {
        background: rgba(243, 239, 230, 0.55);
    }

    .stats-insights-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05), 0 6px 20px rgba(42, 39, 35, 0.04);
        margin-bottom: 1.25rem;
        padding: 1.35rem 1.5rem;
    }

    .stats-insights-card h4,
    .stats-insights-card .stats-chart-title {
        margin-bottom: 1rem;
    }

    .stats-insights-card li {
        color: rgba(42, 39, 35, 0.72);
        font-size: 0.92rem;
        line-height: 1.5;
    }

    .stats-legend-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05);
        margin-bottom: 1.25rem;
        padding: 1rem 1.25rem;
    }

    .stats-period-grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    }

    .stats-period-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05);
        overflow: hidden;
    }

    .stats-period-card-body {
        padding: 0.75rem 0.5rem 0;
    }

    .stats-period-card-footer {
        border-top: 1px solid rgba(42, 39, 35, 0.06);
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1rem;
        font-weight: 500;
        padding: 0.85rem 1rem;
        text-align: center;
    }

    .stats-methodology {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05);
        margin-bottom: 1.25rem;
        padding: 1rem 1.25rem;
    }

    .stats-methodology-text {
        color: rgba(42, 39, 35, 0.62);
        font-size: 0.84rem;
        line-height: 1.55;
        margin: 0;
    }

    .stats-methodology-link {
        color: #8c1515;
        font-weight: 600;
        margin-left: 0.25rem;
        text-decoration: none;
    }

    .stats-methodology-link:hover {
        color: #6f1111;
        text-decoration: underline;
    }

    @media (max-width: 767.98px) {
        .stats-chart-nav {
            gap: 0.5rem;
            margin-bottom: 0.65rem;
        }

        .stats-chart-nav-link {
            font-size: 0.8rem;
            gap: 0.3rem;
            max-width: 49%;
        }

        .stats-chart-header {
            padding: 1.1rem 1rem 0.95rem;
        }

        .stats-chart-body {
            padding: 0.5rem 0.35rem 0.85rem;
        }

        .stats-table-card-header,
        .stats-table-card-body {
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        .stats-table-card-body .table thead th,
        .stats-table-card-body .table tbody td {
            padding-left: 0.65rem;
            padding-right: 0.65rem;
        }
    }
