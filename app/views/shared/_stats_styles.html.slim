css:
    .stats-page {
        background: #f3efe6;
        flex: 1 0 auto;
        width: 100%;
    }

    .stats-page-inner {
        margin: 0 auto;
        max-width: 100%;
        padding: clamp(1.25rem, 3vw, 2.5rem) clamp(1rem, 4vw, 3rem) 3rem;
        width: 100%;
    }

    .stats-page-back {
        align-items: center;
        color: rgba(42, 39, 35, 0.55);
        display: inline-flex;
        font-size: 0.82rem;
        gap: 0.35rem;
        margin-bottom: 1.25rem;
        text-decoration: none;
    }

    .stats-page-back:hover {
        color: #8c1515;
    }

    .stats-hero {
        margin-bottom: 2rem;
    }

    .stats-hero-title {
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(1.75rem, 3vw, 2.35rem);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.15;
        margin: 0 0 0.5rem;
    }

    .stats-hero-subtitle {
        color: rgba(42, 39, 35, 0.62);
        font-size: 1rem;
        line-height: 1.55;
        margin: 0;
        max-width: 42rem;
    }

    .stats-index-grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    }

    .stats-index-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05), 0 6px 20px rgba(42, 39, 35, 0.04);
        color: inherit;
        display: flex;
        flex-direction: column;
        min-height: 100%;
        padding: 1.35rem 1.35rem 1.15rem;
        text-decoration: none;
        transition: box-shadow 0.18s ease, transform 0.18s ease;
    }

    .stats-index-card:hover {
        box-shadow: 0 2px 6px rgba(42, 39, 35, 0.07), 0 10px 28px rgba(42, 39, 35, 0.08);
        color: inherit;
        text-decoration: none;
        transform: translateY(-2px);
    }

    .stats-index-card-top {
        align-items: flex-start;
        display: flex;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .stats-index-card-icon {
        align-items: center;
        background: rgba(140, 21, 21, 0.08);
        border-radius: 12px;
        color: #8c1515;
        display: flex;
        height: 42px;
        justify-content: center;
        width: 42px;
    }

    .stats-index-card-tag {
        background: #eeeae3;
        border-radius: 999px;
        color: rgba(42, 39, 35, 0.62);
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        padding: 0.28rem 0.65rem;
        text-transform: uppercase;
    }

    .stats-index-card-title {
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.2rem;
        font-weight: 500;
        line-height: 1.25;
        margin: 0 0 0.45rem;
    }

    .stats-index-card-desc {
        color: rgba(42, 39, 35, 0.58);
        flex: 1 1 auto;
        font-size: 0.88rem;
        line-height: 1.5;
        margin: 0 0 1rem;
    }

    .stats-index-card-sparkline {
        height: 48px;
        margin-bottom: 1rem;
        opacity: 0.55;
        overflow: hidden;
        width: 100%;
    }

    .stats-index-card-footer {
        align-items: center;
        color: #8c1515;
        display: flex;
        font-size: 0.82rem;
        font-weight: 600;
        gap: 0.35rem;
        margin-top: auto;
    }

    .stats-chart-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05), 0 6px 20px rgba(42, 39, 35, 0.04);
        margin-bottom: 1.25rem;
        overflow: hidden;
    }

    .stats-chart-header {
        align-items: flex-start;
        border-bottom: 1px solid rgba(42, 39, 35, 0.06);
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: space-between;
        padding: 1.35rem 1.5rem 1.15rem;
    }

    .stats-chart-title {
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: clamp(1.35rem, 2.2vw, 1.65rem);
        font-weight: 500;
        letter-spacing: -0.01em;
        line-height: 1.2;
        margin: 0 0 0.35rem;
    }

    .stats-chart-subtitle {
        color: rgba(42, 39, 35, 0.58);
        font-size: 0.92rem;
        line-height: 1.45;
        margin: 0;
        max-width: 40rem;
    }

    .stats-chart-controls {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .stats-pill-group {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .stats-pill {
        background: #eeeae3;
        border-radius: 999px;
        color: rgba(42, 39, 35, 0.68);
        font-size: 0.78rem;
        font-weight: 600;
        padding: 0.38rem 0.85rem;
        text-decoration: none;
        transition: background 0.15s ease, color 0.15s ease;
    }

    .stats-pill:hover {
        background: rgba(140, 21, 21, 0.12);
        color: #8c1515;
        text-decoration: none;
    }

    .stats-pill.is-active {
        background: #8c1515;
        color: #fff;
    }

    .stats-export-btn {
        align-items: center;
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.12);
        border-radius: 10px;
        color: rgba(42, 39, 35, 0.72);
        display: inline-flex;
        font-size: 0.82rem;
        font-weight: 600;
        gap: 0.4rem;
        padding: 0.45rem 0.85rem;
    }

    .stats-export-btn:hover {
        background: #faf8f4;
        border-color: rgba(42, 39, 35, 0.18);
        color: #2a2723;
    }

    .stats-chart-body {
        padding: 0.75rem 1rem 1.25rem;
    }

    .stats-table-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05), 0 6px 20px rgba(42, 39, 35, 0.04);
        margin-bottom: 1.25rem;
        overflow: hidden;
    }

    .stats-table-card-header {
        border-bottom: 1px solid rgba(42, 39, 35, 0.06);
        padding: 1.1rem 1.5rem;
    }

    .stats-table-title {
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1.05rem;
        font-weight: 500;
        margin: 0;
    }

    .stats-table-card-body {
        padding: 0.25rem 0.5rem 0.75rem;
    }

    .stats-table-card-body .table {
        margin-bottom: 0;
    }

    .stats-table-card-body .table thead th {
        background: transparent;
        border-bottom: 1px solid rgba(42, 39, 35, 0.08);
        color: rgba(42, 39, 35, 0.48);
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        padding: 0.85rem 1rem;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .stats-table-card-body .table tbody td {
        border-bottom: 1px solid rgba(42, 39, 35, 0.05);
        color: #2a2723;
        font-size: 0.9rem;
        padding: 0.95rem 1rem;
        vertical-align: middle;
    }

    .stats-table-card-body .table tbody tr:last-child td {
        border-bottom: 0;
    }

    .stats-table-card-body .table-hover tbody tr:hover {
        background: rgba(243, 239, 230, 0.55);
    }

    .stats-insights-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05), 0 6px 20px rgba(42, 39, 35, 0.04);
        margin-bottom: 1.25rem;
        padding: 1.35rem 1.5rem;
    }

    .stats-insights-card h4,
    .stats-insights-card .stats-chart-title {
        margin-bottom: 1rem;
    }

    .stats-insights-card li {
        color: rgba(42, 39, 35, 0.72);
        font-size: 0.92rem;
        line-height: 1.5;
    }

    .stats-legend-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05);
        margin-bottom: 1.25rem;
        padding: 1rem 1.25rem;
    }

    .stats-period-grid {
        display: grid;
        gap: 1.25rem;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    }

    .stats-period-card {
        background: #fff;
        border: 1px solid rgba(42, 39, 35, 0.07);
        border-radius: 16px;
        box-shadow: 0 1px 2px rgba(42, 39, 35, 0.05);
        overflow: hidden;
    }

    .stats-period-card-body {
        padding: 0.75rem 0.5rem 0;
    }

    .stats-period-card-footer {
        border-top: 1px solid rgba(42, 39, 35, 0.06);
        color: #2a2723;
        font-family: edict, "edict Fallback", Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 1rem;
        font-weight: 500;
        padding: 0.85rem 1rem;
        text-align: center;
    }

    @media (max-width: 767.98px) {
        .stats-chart-header {
            padding: 1.1rem 1rem 0.95rem;
        }

        .stats-chart-body {
            padding: 0.5rem 0.35rem 0.85rem;
        }

        .stats-table-card-header,
        .stats-table-card-body {
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        .stats-table-card-body .table thead th,
        .stats-table-card-body .table tbody td {
            padding-left: 0.65rem;
            padding-right: 0.65rem;
        }
    }
