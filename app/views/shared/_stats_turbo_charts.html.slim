    (function() {
        function statsViewportChartHeight() {
            if (window.innerWidth < 992) return null;

            var reserved = window.innerWidth >= 1400 ? 240 : 272;
            return Math.round(Math.max(480, Math.min(window.innerHeight - reserved, 900)));
        }

        function syncStatsChartHeights() {
            var height = statsViewportChartHeight();
            if (!height) return;

            document.querySelectorAll(".stats-chart-body > div[id], .stats-chart-body .stats-region-sunburst[id], .stats-chart-body .stats-region-sankey[id], .stats-chart-body .stats-country-geo-map[id], .stats-period-card-body > div[id]").forEach(function(node) {
                if (!node.id) return;

                if (node.dataset.statsGeoMap === "true") {
                    if (typeof window.drawCountryGeoChart === "function") {
                        window.drawCountryGeoChart();
                    }
                    return;
                }

                node.style.height = height + "px";

                if (node.dataset.geoChartType === "sunburst" || node.dataset.geoChartType === "sankey") {
                    var echartsChart = window.statsGeoCharts && window.statsGeoCharts[node.id];
                    if (echartsChart && typeof echartsChart.resize === "function") {
                        echartsChart.resize({ width: node.clientWidth, height: height });
                    }
                    return;
                }

                var chartkickChart = window.Chartkick && Chartkick.charts && Chartkick.charts[node.id];
                if (!chartkickChart) return;

                if (typeof chartkickChart.redraw === "function") {
                    chartkickChart.redraw();
                    return;
                }

                var chartObject = chartkickChart.getChartObject && chartkickChart.getChartObject();
                if (chartObject && typeof chartObject.resize === "function") {
                    chartObject.resize();
                }
            });
        }

        var resizeTimer;
        function scheduleStatsChartResize() {
            window.clearTimeout(resizeTimer);
            resizeTimer = window.setTimeout(syncStatsChartHeights, 120);
        }

        function bootChartkick() {
            if (window.Chartkick) {
                window.dispatchEvent(new Event("chartkick:load"));
            }
        }

        function refreshStatsCharts() {
            if (document.documentElement.hasAttribute("data-turbo-preview")) return;

            var sankeyChart = document.querySelector(".stats-region-sankey[data-geo-chart-type='sankey']");
            if (sankeyChart) {
                if (typeof window.drawRegionCountrySankey === "function") {
                    window.drawRegionCountrySankey();
                }
                window.setTimeout(syncStatsChartHeights, 150);
                return;
            }

            var sunburstChart = document.querySelector(".stats-region-sunburst[data-geo-chart-type='sunburst']");
            if (sunburstChart) {
                if (typeof window.drawRegionCountrySunburst === "function") {
                    window.drawRegionCountrySunburst();
                }
                window.setTimeout(syncStatsChartHeights, 150);
                return;
            }

            var geoMapChart = document.querySelector(".stats-country-geo-map[data-stats-geo-map='true']");
            if (geoMapChart) {
                if (typeof window.drawCountryGeoChart === "function") {
                    window.drawCountryGeoChart();
                }
                window.setTimeout(syncStatsChartHeights, 150);
                return;
            }

            bootChartkick();
            window.setTimeout(syncStatsChartHeights, 150);
        }

        document.addEventListener("turbo:load", refreshStatsCharts);
        document.addEventListener("turbo:render", refreshStatsCharts);
        document.addEventListener("turbolinks:load", refreshStatsCharts);
        window.addEventListener("resize", scheduleStatsChartResize);
        document.addEventListener("chartkick:load", function() {
            window.setTimeout(syncStatsChartHeights, 50);
        });
    })();
